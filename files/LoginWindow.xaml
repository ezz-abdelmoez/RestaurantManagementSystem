<Window x:Class="SalesManagement.files.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SalesManagement.files"
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
        KeyDown="LoginWindow_OnKeyDown"
        mc:Ignorable="d"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Title="LoginWindow"
        >
     <Border Height="600"  Width="400"
            Padding="20" CornerRadius="20 0 20 0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="20" Color="Black"/>
        </Border.Effect>
        <Border.Background>
            <ImageBrush ImageSource="/assets/login_background.jpg" Stretch="UniformToFill">
                <ImageBrush.RelativeTransform>
                    <TransformGroup>
                        <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                        <SkewTransform AngleX="20" CenterY="0.5" CenterX="0.5"/>
                        <RotateTransform CenterY="0.5" CenterX="0.5"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </ImageBrush.RelativeTransform>
            </ImageBrush>
        </Border.Background>

        <Border Background="{DynamicResource pageBackground}" 
                CornerRadius="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="10">
            <StackPanel 
                    FocusManager.FocusedElement="{Binding ElementName=password}"
                    >

                <ComboBox Name="lan_change_combo" Text="Language" Height="40"
                        IsEditable="False"
                          Margin="10 0"
                          HorizontalContentAlignment="Center">
                    <ComboBoxItem Content="العربية" HorizontalContentAlignment="Center"/>
                    <ComboBoxItem Content="English" HorizontalContentAlignment="Center"/>
                </ComboBox>
                <Label Content="{lex:Loc Key=user_name}" 
                       Foreground="{DynamicResource textColor}"
                       FontSize="20" />
                <ComboBox Name="users_combo" ItemsSource="{Binding}" Height="50" HorizontalAlignment="Left" Margin="0,0,0,0" VerticalAlignment="Top"
              Width="300" TabIndex="1" HorizontalContentAlignment="Center"/>
                <Label Content="{lex:Loc Key=password}" Foreground="{DynamicResource textColor}" Margin="0 20 0 0" FontSize="20"/>
                <PasswordBox KeyDown="password_KeyDown" Name="password" Height="50" HorizontalAlignment="Left"
                 Margin="0,0,0,20" VerticalAlignment="Top" Width="300" TabIndex="2"
                 HorizontalContentAlignment="Center"/>
                <Button Click="login_btn_click" Style="{DynamicResource dangerBtn}" Name="button1" Content="{lex:Loc Key=enter}" Height="50" HorizontalAlignment="Left"
            Margin="0,10,0,0" VerticalAlignment="Top" Width="300" TabIndex="3" FontSize="18"/>


                <Button Style="{StaticResource dangerBtn1}" 
                    Click="Button_Click"
                    Width="100"
                    Height="50"
                    Margin="0 50 0 0"
                    Content="{lex:Loc Key=exit}"
                    />


            </StackPanel>
        </Border>
        
    </Border>
</Window>
