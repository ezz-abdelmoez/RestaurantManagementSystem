<UserControl x:Class="SalesManagement.files.controllers.ClientController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d">
    <Border Background="{DynamicResource pageBackground}"
            CornerRadius="20">
        <Grid >
          
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <ComboBox Visibility="Collapsed" Name="client_combo" Grid.Row="4"/>

                <Border Background="{DynamicResource greenDarkLinear}" 
                    CornerRadius="20 20 0 0"
                    >
                    <Grid>
                        <Label HorizontalAlignment="Center" Content="{lex:Loc Key=clients}"
                               Style="{StaticResource pageTitle}"/>

                        <Border Style="{StaticResource imag_border}"
                                HorizontalAlignment="Right"
                                Margin="5"
                                Height="50">
                            <Image Source="/assets/img/refresh-button.png"
                                   MouseDown="refresh_page_md"></Image>
                        </Border>

                    </Grid>
                </Border>

                <Grid Grid.Row="1" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=search}"/>

                            <TextBox Name="search_by_name_bp" 
                                     TextChanged="search_by_name_bp_TextChanged"
                                     MaxWidth="400" MinWidth="200" Grid.Row="1"/>

                        </Grid>

                    </Border>
                    <Border Margin="5 5 5 10"   
                        Grid.Column="1"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=tel}"/>

                            <TextBox Name="search_by_phone"
                                     TextChanged="search_by_name_bp_TextChanged"
                                     PreviewTextInput="search_by_phone_PreviewTextInput"
                                     MaxWidth="400" MinWidth="200" Grid.Row="1"/>

                        </Grid>

                    </Border>
                </Grid>

                <ListView x:Name="clientListview" 
                          Grid.Row="2"
                          ItemsSource="{Binding}"
                          Background="{DynamicResource subBackground}"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                    <ListView.View>
                        <GridView>

                            <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                            DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                            <GridViewColumn Header="{lex:Loc Key=name}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox KeyDown="update_client_name_text_keydown" 
                                                 Text="{Binding Path=client}" 
                                               MaxWidth="200"
                                               TextWrapping="Wrap"
                                               AcceptsReturn="True"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="{lex:Loc Key=address}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox KeyDown="update_address_tb_keydown" 
                                                   Text="{Binding Path=address}" 
                                               MinWidth="150" MaxWidth="300"  
                                                   TextWrapping="Wrap"
                                                   AcceptsReturn="True"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="{lex:Loc Key=tel}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox KeyDown="update_tel_tb_keydown" Text="{Binding Path=tel}" 
                                               MinWidth="150"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="{lex:Loc Key=email}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox KeyDown="update_email_tb_keydown" Text="{Binding Path=email}" 
                                               MinWidth="150" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="{lex:Loc Key=delete}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Style="{StaticResource imag_border}" Width="100"
                                                Height="50">
                                            <Image 
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                MouseDown="delete_client_img_mousedown" Source="delete.png"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Border Grid.Row="3" Padding="5" Margin="5" 
                        CornerRadius="20"
                        Background="{DynamicResource pageBackground}"
                        >
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="5" BlurRadius="20" Color="{DynamicResource shadow1}"/>
                    </Border.Effect>
                    <Grid  HorizontalAlignment="Center"
                                  >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Margin="5 5 5 10" 
                                    HorizontalAlignment="Center"
                                    CornerRadius="20 20 20 0"
                                    Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=name}"/>

                                <TextBox x:Name="client_name_tb" MaxWidth="200"
                                         KeyDown="client_name_tb_KeyDown"
                                         TextAlignment="Center"
                                         Grid.Row="1"/>

                            </Grid>

                        </Border>

                        <Border Margin="5 5 5 10" Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    CornerRadius="20 20 20 0"
                                    Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=tel}"/>

                                <TextBox x:Name="client_tel_tb" MaxWidth="200"
                                         PreviewTextInput="search_by_phone_PreviewTextInput"
                                         KeyDown="client_name_tb_KeyDown"
                                         TextAlignment="Center"
                                         Grid.Row="1"/>

                            </Grid>

                        </Border>

                        <Border Margin="5 5 5 10" Grid.Column="2"
                                    HorizontalAlignment="Center"
                                    CornerRadius="20 20 20 0"
                                    Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=address}"/>

                                <TextBox x:Name="client_address_tb" MaxWidth="500"
                                         Padding="0 2"
                                         KeyDown="client_name_tb_KeyDown"
                                         TextAlignment="Center"
                                         Grid.Row="1"/>

                            </Grid>

                        </Border>

                        <Border Margin="5 5 5 10" Grid.Column="3"
                                    HorizontalAlignment="Center"
                                    CornerRadius="20 20 20 0"
                                    Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=email}"/>

                                <TextBox  MaxWidth="200"
                                          KeyDown="client_name_tb_KeyDown"
                                          Padding="0 2"
                                          Name="client_email_tb"
                                         TextAlignment="Center"
                                         Grid.Row="1"/>

                            </Grid>

                        </Border>

                        <Border Grid.Column="4" Style="{StaticResource imag_border}" Width="100" Height="100">
                            <Image Source="save.png" ToolTip="Save" MouseDown="add_new_client_img_mousedown"/>
                        </Border>
                    </Grid>
                </Border>
                

                <Border 
                        Margin="5"
                        Grid.Row="4"
                        CornerRadius="20">

                    <Border Margin="5"   
                            Height="40"
                            HorizontalAlignment="Left"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="{lex:Loc Key=number}"/>

                            <TextBox Name="tot_tb" IsEnabled="False" MinWidth="200" Grid.Column="1"/>

                        </Grid>

                    </Border>

                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
