<UserControl x:Class="SalesManagement.files.controllers.CashierController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
                xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d">
    <Border Background="{DynamicResource pageBackground}"
            CornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="0"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>


            <Border Grid.Row="1" Padding="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Left"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="{lex:Loc Key=user}"/>

                            <ComboBox Name="username_combo" SelectionChanged="Username_combo_OnSelectionChanged" 
                                      IsEditable="True"
                                      ItemsSource="{Binding}" Grid.Column="1"/>

                        </Grid>

                    </Border>
                    <Border Margin="5 5 5 10"   
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="{lex:Loc Key=value}"/>

                            <TextBox MinHeight="50" Name="user_values_tb"
                                     IsEnabled="False"
                                     MinWidth="200" Grid.Column="1"/>

                        </Grid>

                    </Border>
                    
                    <Border Style="{StaticResource imag_border}" Visibility="Collapsed"
                            HorizontalAlignment="Right"
                            Grid.Column="2"
                            Margin="5"
                            Height="50">
                        <Image Source="/assets/img/refresh-button.png"
                               MouseDown="refresh_page_md"></Image>
                    </Border>
                    
                </Grid>
            </Border>

            <Border Margin="5"   
                            Grid.Row="2"
                    MinHeight="60"
                            HorizontalAlignment="Stretch"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource pageBackground}">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="10" BlurRadius="20" Color="{DynamicResource shadow1}"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lex:Loc Key=safe_settlement}"
                           FontWeight="Bold" FontSize="20" Foreground="{DynamicResource textColor}"
                           Margin="5"/>

                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=supply}"/>

                                <TextBox Name="supply_enter_tb" MaxWidth="300" 
                                         PreviewTextInput="supply_enter_tb_PreviewTextInput"
                                         MinWidth="150" Grid.Row="1"/>

                            </Grid>

                        </Border>

                        <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                                Grid.Column="1"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=money_deficit}"/>

                                <TextBox Name="lack_enter_tb" 
                                         PreviewTextInput="supply_enter_tb_PreviewTextInput"
                                         MaxWidth="300" MinWidth="150" Grid.Row="1"/>

                            </Grid>

                        </Border>

                        <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                                Grid.Column="2"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=cashier_remains}"/>

                                <TextBox Name="remain_enter_tb" 
                                         PreviewTextInput="supply_enter_tb_PreviewTextInput"
                                         MaxWidth="300" MinWidth="150" Grid.Row="1"/>

                            </Grid>

                        </Border>

                        <Button Grid.Column="4" Width="120" Click="settle_click_btn"
                                Margin="5"
                                Style="{StaticResource dangerBtn}"
                                Height="50" Content="{lex:Loc Key=settlement}"
                                />

                    </Grid>

                </Grid>

            </Border>

            <Border Margin="5 5 5 0"   
                            Grid.Row="3"
                    MinHeight="60"
                            HorizontalAlignment="Stretch"
                            CornerRadius="20 20 20 0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lex:Loc Key=search}"
                           FontWeight="Bold" FontSize="20" Foreground="{DynamicResource textColor}"
                           Margin="5"/>

                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Margin="5 5 5 0"   
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=day}"/>

                                <TextBox Name="day_tb" Width="60" MinWidth="60"
                                         MaxLength="2"
                                         PreviewTextInput="day_tb_PreviewTextInput"
                                         TextChanged="Day_tb_OnTextChanged"
                                         TextAlignment="Center"
                                         Grid.Row="1"/>

                            </Grid>

                        </Border>

                        <Border Margin="5 5 5 0"   
                            HorizontalAlignment="Center"
                                Grid.Column="1"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=month}"/>

                                <TextBox Name="month_tb" 
                                         Width="60" MinWidth="60"
                                         MaxLength="2"
                                         PreviewTextInput="day_tb_PreviewTextInput"
                                         TextChanged="Day_tb_OnTextChanged"
                                         TextAlignment="Center"
                                          Grid.Row="1"/>

                            </Grid>

                        </Border>

                        <Border Margin="5 5 5 0"   
                            HorizontalAlignment="Center"
                                Grid.Column="2"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=year}"/>

                                <TextBox Name="year_tb" Width="60" MinWidth="80"
                                         MaxLength="4"
                                         PreviewTextInput="day_tb_PreviewTextInput"
                                         Grid.Row="1"
                                         TextChanged="Day_tb_OnTextChanged"
                                         TextAlignment="Center"
                                         />

                            </Grid>

                        </Border>

                        <ComboBox Name="safe_comobo" Grid.Column="4" SelectedIndex="0"
                                  SelectionChanged="Safe_comobo_OnSelectionChanged"
                                  IsEditable="False"
                                  >
                            <ComboBoxItem Content="{lex:Loc Key=all}"/>
                            <ComboBoxItem Content="{lex:Loc Key=supply}"/>
                            <ComboBoxItem Content="{lex:Loc Key=settlement}"/>
                        </ComboBox>

                    </Grid>

                </Grid>

            </Border>

            <ListView x:Name="safeListview"  Background="{DynamicResource subBackground}"
                      Grid.Row="4"
                                  HorizontalContentAlignment="Stretch"
                                  
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                <ListView.View>
                    <GridView>

                        <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                        DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                        <GridViewColumn Header="{lex:Loc Key=value}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=cash}" 
                                               Foreground="Black"
                                               MinWidth="150" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=description}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label 
                                               Foreground="Black"
                                               Width="300" Padding="5" FontSize="20">
                                        <Label.Content>
                                            <AccessText TextWrapping="Wrap" Text="{Binding Path=det}"/>
                                        </Label.Content>
                                    </Label>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=date}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=safe_date}" 
                                               Foreground="Black"
                                               MinWidth="150" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=money_deficit}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=lack}" 
                                               Foreground="Black"
                                               MinWidth="150" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=remaining}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=remain}"
                                               Foreground="Black"
                                               MinWidth="150" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>

            </ListView>

            <Border Grid.Row="5"
                    Margin="5"
                    CornerRadius="20"
                    Padding="10">
                <Grid>
                    <TextBox Name="lack_tb" HorizontalAlignment="Left" IsEnabled="False"
                             />
                    <TextBox Name="cash_tb" HorizontalAlignment="Right" Margin="0 0 10 0"
                             IsEnabled="False"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</UserControl>
