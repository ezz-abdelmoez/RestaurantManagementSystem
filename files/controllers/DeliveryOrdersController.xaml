<UserControl x:Class="SalesManagement.files.controllers.DeliveryOrdersController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
            lex:LocalizeDictionary.DesignCulture="en-US"
            lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
            lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d" >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Border  Margin="5"   
                HorizontalAlignment="Center"
                        CornerRadius="20 20 20 0"
                Background="{StaticResource orangeLightLinear}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Label Content="{lex:Loc Key=delv_name}"/>
                <Border CornerRadius="20, 0, 20, 0" 
                                        Grid.Column="1" >
                    <ComboBox Name="delv_combo" MinWidth="300" MaxWidth="400" FontSize="20" 
                              SelectionChanged="delv_combo_SelectionChanged">
                        
                    </ComboBox>
                </Border>

                <Border Style="{StaticResource imag_border}" Visibility="Collapsed"
                        Grid.Column="2"
                        Margin="5"
                        Height="50">
                    <Image Source="/assets/img/refresh-button.png"
                           MouseDown="refresh_page_md"></Image>
                </Border>


            </Grid>

        </Border>

        <ListView x:Name="ordDevListview" Grid.Row="1" Background="{StaticResource subBackground}"
                                  HorizontalContentAlignment="Stretch"
                  ItemsSource="{Binding}"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

            <ListView.View>
                <GridView>

                    <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                    DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                    <GridViewColumn Header="{lex:Loc Key=bill_num}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Label Content="{Binding Path=order_no}" 
                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="100"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="{lex:Loc Key=client}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Label 
                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150"  >
                                    <Label.Content>
                                        <AccessText TextWrapping="Wrap" Text="{Binding Path=client}"/>
                                    </Label.Content>
                                </Label>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="{lex:Loc Key=value}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Label Content="{Binding Path=tot}" 
                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="{lex:Loc Key=date}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Label Content="{Binding Path=operation_date}" 
                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="{lex:Loc Key=done}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border  Grid.Column="4" MinWidth="100" Height="50" 
                                         Style="{StaticResource imag_border}">
                                    <Image Source="previos_sail.png" RenderTransformOrigin="0.5,0.5" 
                                           MouseDown="pay_delv_bill_img_md"
                                           >
                                        <Image.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform/>
                                                <SkewTransform/>
                                                <RotateTransform Angle="180"/>
                                                <TranslateTransform/>
                                            </TransformGroup>
                                        </Image.RenderTransform>
                                    </Image>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>



        </ListView>

        <Border CornerRadius="20" Grid.Row="2">

            <Grid>
                <Border  Margin="5"   
                        HorizontalAlignment="Left"
                        Grid.Row="1"
                        CornerRadius="20 0 20 0"
                        Background="{DynamicResource orangeLightLinear}">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="{lex:Loc Key=total}" FontSize="18"/>

                        <TextBox  Name="tot_dev_order_price_tb" Grid.Column="1"
                                     />

                    </Grid>

                </Border>

                <Button HorizontalAlignment="Right" Margin="10 0" Click="pay_all_delv_btn_click"
                    Style="{StaticResource dangerBtn}" Width="150" Height="40"
                        Content="{lex:Loc Key=pay_all}"/>
            </Grid>
            



        </Border>
    </Grid>
</UserControl>
