<UserControl x:Class="SalesManagement.files.controllers.DeliveryController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d" >
    <Border Background="#B2D9D9D9"
            CornerRadius="0 0 20 20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Border Margin="5 5 5 10"  x:Name="new_dev_border" Visibility="Collapsed"
                    Padding="10"
                            HorizontalAlignment="Center"
                                Grid.Column="1"
                            CornerRadius="20 20 20 0"
                            Style="{StaticResource border_shadow}"
                    Background="{StaticResource orangeLightLinear}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Label Content="{lex:Loc Key=name}"/>

                    <TextBox x:Name="dev_name_tb" MaxWidth="300" MinWidth="300" Grid.Column="1"
                                         TextAlignment="Center"
                                         />

                    <Label Content="{lex:Loc Key=tel}" Grid.Row="2"
                           />

                    <TextBox x:Name="dev_phone_tb"  MaxWidth="300" MinWidth="300" Grid.Column="1"
                             Grid.Row="2"
                                         TextAlignment="Center"
                                         />

                    <Label Content="{lex:Loc Key=address}" Grid.Row="4"/>

                    <TextBox x:Name="dev_address_tb"  MaxWidth="300" MinWidth="300" Grid.Column="1"
                             Grid.Row="4"
                                         TextAlignment="Center"
                                         />

                    <Label Content="{lex:Loc Key=email}" Grid.Row="6"/>

                    <TextBox x:Name="dev_email_tb"  MaxWidth="300" MinWidth="300" Grid.Column="1"
                             Grid.Row="6"
                                         TextAlignment="Center"
                                         />

                    <Border  Width="100" Height="100" Grid.Column="2"
                            Grid.RowSpan="7"
                            Style="{StaticResource imag_border}"
                            Margin="20 0 20 0">
                        <Image Source="save.png" MouseDown="add_new_dev_img_md"/>
                    </Border>

                </Grid>

            </Border>

            <Border Grid.Row="1"  Style="{StaticResource border_shadow}"
                    HorizontalAlignment="Center"
                    CornerRadius="0 0 20 20"
                    >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lex:Loc Key=search}" Foreground="{StaticResource textColor}"/>

                    <TextBox x:Name="search_tb" MaxWidth="300" MinWidth="300" Grid.Column="1"
                             TextChanged="search_tb_TextChanged"
                             FontSize="24" FontWeight="ExtraBold"
                                         TextAlignment="Center"
                                         />

                    <Border Style="{StaticResource imag_border}" Width="60"
                            Grid.Column="3"
                            Height="60">
                        <Image Source="new.png" MouseDown="show_new_dev_border_img_md"/>
                    </Border>
                </Grid>
            </Border>

            <ListView x:Name="devListview" 
                      Grid.Row="2"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                <ListView.View>
                    <GridView>

                        <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                        DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />
                        
                        <GridViewColumn Header="{lex:Loc Key=name}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=delivery_man}" 
                                             KeyDown="dev_name_change_keydown"
                                               MinWidth="100" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=address}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=address}" 
                                             KeyDown="dev_address_change_keydown"
                                               MinWidth="150"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=tel}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=tel}" 
                                             KeyDown="dev_phone_change_keydown"
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                               MinWidth="100"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=email}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=email}" 
                                             KeyDown="dev_email_change_keydown"
                                               MinWidth="100"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=delete}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="50" Height="50" 
                                            Style="{StaticResource imag_border}"
                                            HorizontalAlignment="Center">
                                        <Image Source="delete.png" MouseDown="delete_dev_img_md"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>

            </ListView>

            <Border Grid.Row="3"  Background="{StaticResource orangeLightLinear}"
                    HorizontalAlignment="Left"
                    CornerRadius="0 0 20 20"
                   >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lex:Loc Key=total}"/>

                    <TextBox x:Name="total_tb" MaxWidth="300" MinWidth="300" Grid.Column="1"
                                         TextAlignment="Center"
                                         />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
