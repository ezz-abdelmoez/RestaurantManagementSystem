<UserControl x:Class="SalesManagement.files.controllers.EmployeeController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d" >
    <Border Background="{DynamicResource pageBackground}"
            CornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Border MinHeight="60" 
                    MinWidth="200"
                    CornerRadius="20 20 0 0"
                    Background="{StaticResource greenDarkLinear}">
                <Label Content="{lex:Loc Key=emp}" Style="{StaticResource pageTitle}"/>

            </Border>

            <Border Grid.Row="1" HorizontalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource imag_border}"
                           >
                        <Image Width="80" Height="80" Source="new.png" ToolTip="{lex:Loc Key=add_new_emp}"
                               MouseDown="add_employee_img_mouse_down"/>
                    </Border>

                    <Border Style="{StaticResource imag_border}" Grid.Column="1"
                            >
                        <Image MouseDown="emp_spends_img_mouse_down" Width="80" 
                               ToolTip="{lex:Loc Key=spends}"
                               Height="80" Source="wallet.png"/>
                    </Border>

                    <Border Style="{StaticResource imag_border}" Grid.Column="2"
                            >
                        <Image MouseDown="emp_holidays_mouse_down" Width="80"
                               ToolTip="{lex:Loc Key=holidays}"
                               Height="80" Source="day-off.png"/>
                    </Border>

                    <Border Style="{StaticResource imag_border}" Grid.Column="3"
                            Margin="10 0"
                            >
                        <Image Width="80" Height="80"
                               MouseDown="salary_details_window_img_md"
                               ToolTip="{lex:Loc Key=salary}"
                               Source="papermoney.png"/>
                    </Border>
                </Grid>
            </Border>

            <Border Margin="5 5 5 10"   
                    Style="{StaticResource border_shadow}"
                            Grid.Row="2"
                    MinHeight="60"
                            HorizontalAlignment="Stretch"
                            CornerRadius="20 20 20 0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lex:Loc Key=search}"
                           Foreground="{DynamicResource textColor}"
                           FontWeight="Bold" FontSize="20"
                           Margin="5"/>

                    <Grid Grid.Column="1" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="{lex:Loc Key=job}"/>

                                <ComboBox Name="jobs_combo" MaxWidth="400" MinWidth="200" Grid.Column="1"
                                          IsEditable="True"
                                          SelectionChanged="jobs_combo_SelectionChanged"/>

                            </Grid>

                        </Border>
                        <Border Margin="5 5 5 10"   
                        Grid.Column="1"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="{lex:Loc Key=name}"/>

                                <TextBox x:Name="search_tb" MaxWidth="400" MinWidth="200" Grid.Column="1"
                                         TextChanged="search_tb_TextChanged"/>

                            </Grid>

                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <ListView x:Name="empListview"  Grid.Row="3"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                        DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                        <GridViewColumn Header="{lex:Loc Key=job}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=eccup}" 
                                             KeyDown="eccup_change_lv_tb"
                                               MinWidth="100"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=name}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=emp}" 
                                             KeyDown="emp_name_change_lv_tb"
                                               MinWidth="100"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=address}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=address}" 
                                             KeyDown="emp_address_change_lv_tb"
                                               MinWidth="100"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=tel}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=tel}"
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                             KeyDown="emp_phone_change_lv_tb"
                                               MinWidth="100"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=salary}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=ratb}"
                                             PreviewTextInput="TextBox_PreviewTextInput_1"
                                             KeyDown="emp_salary_change_lv_tb"
                                               FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=work_hours}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=work_hours}"
                                             KeyDown="emp_work_hours_change_lv_tb"
                                             PreviewTextInput="TextBox_PreviewTextInput_1"
                                               MinWidth="120"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="{lex:Loc Key=holidays}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=vac_no}"
                                             KeyDown="emp_holiday_change_lv_tb"
                                               PreviewTextInput="TextBox_PreviewTextInput_1"
                                               MinWidth="100"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        
                        <GridViewColumn Header="{lex:Loc Key=spends}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=solfa}"
                                             IsEnabled="False"
                                             PreviewTextInput="TextBox_PreviewTextInput_1"
                                               MinWidth="100"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=delete}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border HorizontalAlignment="Center" Width="50" Height="50" 
                                            Style="{StaticResource imag_border}">
                                        <Image 
                                               MouseDown="delete_emp_img_mouse_down"
                                               Source="delete.png"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>

            </ListView>

            <Border 
                        Grid.Row="4"
                        MinWidth="100"
                        CornerRadius="20">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Margin="5 5 5 10"   
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="{lex:Loc Key=number}"/>

                            <TextBox x:Name="num_tb" IsEnabled="False" MinWidth="100" Grid.Column="1"/>

                        </Grid>

                    </Border>

                    <Border Margin="5 5 5 10"  Grid.Column="1"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="{lex:Loc Key=total_salaries}"/>

                            <TextBox x:Name="tot_salary_tb" IsEnabled="False" MinWidth="100" Grid.Column="1"/>

                        </Grid>

                    </Border>

                    <Border Margin="5 5 5 10"  Grid.Column="2"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="{lex:Loc Key=total_borrow}"/>

                            <TextBox x:Name="tot_borrow_tb"  IsEnabled="False" MinWidth="100" Grid.Column="1"/>

                        </Grid>

                    </Border>
                </Grid>
                

            </Border>


            <!--#region add new emp ui handler-->
            <Border  Grid.RowSpan="5" Name="new_emp_border" 
                    Visibility="Collapsed"
                CornerRadius="20" Padding="5" Background="#B3D9D9D9">
                <Border Style="{StaticResource border_shadow}" HorizontalAlignment="Center"
                        
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="10 0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>

                            <Border CornerRadius="20 0 0 0" Grid.Column="0"
                                    Margin="0 5 0 0"
                                    Padding="10"
                                Background="{DynamicResource orangeLightLinear}">
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Label Content="{lex:Loc Key=job}" FontSize="20"
                                       Margin="0 0 0 0"/>


                                    <ComboBox Name="new_eccup_combo" Width="200" 
                                              Grid.Column="1" IsEditable="True"/>
                                </Grid>
                            </Border>

                            <Border CornerRadius="0 0 20 0" Grid.Column="1" 
                                    Margin="0 5 0 0"
                                    Padding="10"
                                Background="{DynamicResource orangeLightLinear}">
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Label Content="{lex:Loc Key=name}" FontSize="20"
                                       />

                                    <TextBox x:Name="new_emp_name_tb" 
                                         Width="260" Grid.Column="1"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Margin="5 5 5 10" Grid.Row="2"
                                MinHeight="60"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border  
                                    HorizontalAlignment="Stretch"
                                    CornerRadius="20 20 20 0"
                                    Background="{StaticResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Content="{lex:Loc Key=address}"/>

                                        <TextBox x:Name="new_address_tb"  Width="600"
                                                 MinWidth="600" Grid.Row="1"/>

                                    </Grid>

                                </Border>

                            </Grid>
                        </Border>

                        <Border Margin="5 5 5 0" Grid.Row="3"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Content="{lex:Loc Key=salary}"/>

                                        <TextBox x:Name="new_emp_salary_tb"
                                                 PreviewTextInput="TextBox_PreviewTextInput_1"
                                                 Width="200" Grid.Row="1"/>

                                    </Grid>

                                </Border>
                                <Border Margin="5 5 5 10"   
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Content="{lex:Loc Key=work_hours}"/>

                                        <TextBox x:Name="new_emp_wh_tb" 
                                                 PreviewTextInput="TextBox_PreviewTextInput_1"
                                                 Width="200" Grid.Row="1"/>

                                    </Grid>

                                </Border>
                                <Border Margin="5 5 5 10"   
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Content="{lex:Loc Key=tel}"/>

                                        <TextBox x:Name="new_emp_phone_tb" 
                                                 PreviewTextInput="TextBox_PreviewTextInput"
                                                 Width="200" Grid.Row="1"/>

                                    </Grid>

                                </Border>
                            </Grid>
                        </Border>

                        <Border Margin="5 5 5 0" Grid.Row="4"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Content="{lex:Loc Key=date_of_hiring}"/>

                                        <DatePicker Width="200" Grid.Row="1" Height="50"
                                                Name="new_date_hiring_dp"
                                                Text="Add Date"/>

                                    </Grid>

                                </Border>
                                <Border Margin="5 5 5 10"   
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Content="{lex:Loc Key=holidays_balance}"/>

                                        <TextBox x:Name="new_holiday_balance_tb"
                                                 PreviewTextInput="TextBox_PreviewTextInput_1"
                                                 Width="200" Grid.Row="1"/>

                                    </Grid>

                                </Border>
                            </Grid>
                        </Border>

                        <Button x:Name="save_new_emp" Style="{StaticResource dangerBtn}" Grid.Row="5"
                            Click="save_new_emp_Click"
                        Width="200" Height="60" Content="{lex:Loc Key=save}"/>

                        <Button Style="{StaticResource dangerBtn1}" Grid.Row="5" HorizontalAlignment="Left"
                            Click="hide_new_emp_ui_click"
                        Width="100" Height="60" Content="{lex:Loc Key=cancel}"/>

                    </Grid>
                </Border>
                
            </Border>
            <!--#endregion-->
            
            
            <!--#region Borrow ui window handler-->
            <Border x:Name="borrow_border" Style="{StaticResource border_shadow}" Grid.RowSpan="5" 
                    Margin="10"
                    Visibility="Collapsed"
                    CornerRadius="20" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource imag_border}"
                            HorizontalAlignment="Right"
                            Width="50" Height="50">
                        <Image Source="delete.png" 
                               MouseDown="hide_borrow_border"
                               />
                    </Border>

                    <Border>
                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Left"
                            CornerRadius="20 0 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Content="{lex:Loc Key=emp1}"/>

                                    <ComboBox Name="borrow_emp_combo" 
                                              SelectionChanged="borrow_emp_combo_SelectionChanged"
                                              MinWidth="200" IsEditable="True"
                                      Height="40"
                                      Grid.Column="1"/>

                                </Grid>

                            </Border>

                            <Border Margin="5 5 5 10"   
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=month}"/>

                                    <TextBox TextChanged="spend_month_tb_TextChanged" 
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                             MaxLength="2"
                                             x:Name="spend_month_tb" MinWidth="60" Grid.Row="1" Width="60"/>

                                </Grid>

                            </Border>

                            <Border Margin="5 5 5 10"   
                            Grid.Column="3"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=year}"/>

                                    <TextBox TextChanged="spend_month_tb_TextChanged" 
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                             MaxLength="4"
                                             x:Name="spend_year_tb" MinWidth="80" Width="80" Grid.Row="1"/>

                                </Grid>

                            </Border>

                        </Grid>
                    </Border>

                    <Border Margin="5 5 5 10"   Grid.Row="1"
                    Padding="5"
                            CornerRadius="20 0 20 0"
                            Style="{StaticResource border_shadow}"
                            HorizontalAlignment="Center">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Margin="5 5 5 10"  
                            HorizontalAlignment="Center"
                            CornerRadius="20 0 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=date}"/>

                                    <DatePicker Name="spend_date_dp" MinWidth="150" 
                                        Text="Add Date"
                                        MinHeight="50"
                                        Grid.Row="1"/>

                                </Grid>

                            </Border>

                            <Border Margin="5 5 5 10"  Grid.Column="1"
                            HorizontalAlignment="Center"
                            CornerRadius="20 0 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=value}"/>

                                    <TextBox x:Name="spend_value_tb" MinWidth="150" 
                                             PreviewTextInput="TextBox_PreviewTextInput_1"
                                        Grid.Row="1"/>

                                </Grid>

                            </Border>

                            <Border Margin="5 5 5 10"  Grid.Column="2"
                            HorizontalAlignment="Center"
                            CornerRadius="20 0 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=description}"/>

                                    <ComboBox x:Name="spend_desc_combo"
                                        Grid.Row="1">
                                        <ComboBoxItem Content="{lex:Loc Key=spends}"/>
                                        <ComboBoxItem Content="{lex:Loc Key=salary}"/>
                                    </ComboBox>

                                </Grid>

                            </Border>

                            <Border Margin="5 5 5 10"  Grid.Column="3"
                            HorizontalAlignment="Center"
                            CornerRadius="20 0 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=notes}"/>

                                    <TextBox x:Name="spend_notes_tb" MinWidth="250" 
                                        MinHeight="50"
                                        Grid.Row="1"/>

                                </Grid>

                            </Border>

                            <Button x:Name="add_new_emp_borrow" 
                                    Click="add_new_emp_borrow_Click"
                                    Content="{lex:Loc Key=add}" Width="150" Height="50" Grid.Column="4"
                                Margin="10 0 10 0"
                                Style="{StaticResource dangerBtn}"/>

                        </Grid>
                    </Border>

                    <ListView x:Name="spendListview" Grid.Row="2"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                        <ListView.View>
                            <GridView>

                                <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                                DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                                <GridViewColumn Header="{lex:Loc Key=amount}">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Label Content="{Binding Path=cash}" 
                                               Foreground="{DynamicResource textColor}"
                                               MinWidth="100"  FontSize="20"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="{lex:Loc Key=description}">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Label Content="{Binding Path=discrption}" 
                                               Foreground="{DynamicResource textColor}"
                                               MinWidth="110"  FontSize="20"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="{lex:Loc Key=notes}">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Label Content="{Binding Path=notes}" 
                                               Foreground="{DynamicResource textColor}"
                                               MinWidth="150"  FontSize="20"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="{lex:Loc Key=spend_date}">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Label Content="{Binding Path=spend_date}" 
                                               Foreground="{DynamicResource textColor}"
                                               MinWidth="150" 
                                                   FontSize="20"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="{lex:Loc Key=delete}">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border HorizontalAlignment="Center" 
                                                    Width="50" Height="50"
                                            Style="{StaticResource imag_border}">
                                                <Image  Source="delete.png"
                                                       MouseDown="delete_spend_mouse_down_img"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                            </GridView>
                        </ListView.View>

                    </ListView>

                    <Border 
                        Grid.Row="3"
                    VerticalAlignment="Bottom"
                        CornerRadius="20">

                        <Border Margin="5 5 5 5"   
                            HorizontalAlignment="Left"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="{lex:Loc Key=total}"/>

                                <TextBox x:Name="tot_spend_tb" IsEnabled="False" MinWidth="150" Grid.Column="1"/>

                            </Grid>

                        </Border>


                    </Border>

                </Grid>
            </Border>
            <!--#endregion-->

        </Grid>
    </Border>
</UserControl>
