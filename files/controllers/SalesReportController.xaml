<UserControl x:Class="SalesManagement.files.controllers.SalesReportController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d" >
    <Grid Background="{DynamicResource pageBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Margin="5" HorizontalAlignment="Center">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Height="40" Margin="5 5 0 10"   
                HorizontalAlignment="Center"
                        CornerRadius="20 20 20 0"
                Background="{DynamicResource orangeLightLinear}">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="{lex:Loc Key=search_from}"/>
                        
                        <DatePicker Name="from_date_dp"
                                    SelectedDateChanged="from_date_dp_SelectedDateChanged"
                                    Grid.Column="1" Width="200" Text="Add Date"/>

                        <TextBox MinWidth="100" Grid.Column="2"/>

                    </Grid>

                </Border>

                <Border Height="40" Margin="5 5 0 10"
                        Grid.Column="1"
                HorizontalAlignment="Center"
                        CornerRadius="20 20 20 0"
                Background="{DynamicResource orangeLightLinear}">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="{lex:Loc Key=to}"/>

                        <DatePicker Name="to_date_dp" 
                                    SelectedDateChanged="from_date_dp_SelectedDateChanged"
                                    Grid.Column="1" Width="200" Text="Add Date"/>

                        <TextBox MinWidth="100" Grid.Column="2"/>

                    </Grid>

                </Border>

                <Border Style="{StaticResource imag_border}"
                        Grid.Column="2"
                        Margin="5"
                        Height="50">
                    <Image Source="/assets/img/refresh-button.png"
                           MouseDown="refresh_page_md"></Image>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <TabControl Background="Transparent">
                <TabItem Background="Transparent" Height="40">
                    <TabItem.Header >
                        <Border MinWidth="100" 
                                CornerRadius="20"
                                 Style="{DynamicResource blueLightRadialBorder}">
                            <Label Content="{lex:Loc Key=sales}" FontSize="20"/>
                        </Border>
                    </TabItem.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="160"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="60"/>
                        </Grid.RowDefinitions>

                        <Border Margin="5" Background="{DynamicResource pageBackground}"
                                CornerRadius="20">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="5" BlurRadius="20" Color="{DynamicResource shadow1}"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="{DynamicResource greenDarkLinear}"
                                    Padding="5"
                                    CornerRadius="20 0 0 20">
                                    <StackPanel 
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <Image Source="search.png" Width="60" Height="60"
                                           Margin="0 0 10 0"/>
                                        <Label Content="{lex:Loc Key=search}" FontSize="24"/>
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border
                                        CornerRadius="0 20 0 0"
                                        Padding="5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Height="50" Margin="5 0 0 0"  
                                            HorizontalAlignment="Center"
                                                    CornerRadius="20 0 20 0"
                                            Background="{DynamicResource orangeLightLinear}">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Label Content="{lex:Loc Key=order_type}"/>

                                                    <ComboBox Name="order_type_combo" MinWidth="150"
                                                              SelectionChanged="user_combo_SelectionChanged"
                                                          Grid.Column="1" FontSize="18"
                                                          IsEditable="True">
                                                        <ComboBoxItem Content="{lex:Loc Key=take_away}"/>
                                                        <ComboBoxItem Content="{lex:Loc Key=hall}"/>
                                                        <ComboBoxItem Content="{lex:Loc Key=delivery}"/>
                                                        <ComboBoxItem Content="{lex:Loc Key=reservation}"/>
                                                    </ComboBox>
                                                </Grid>

                                            </Border>

                                            <Border Height="50" Margin="10 0 0 0"  
                                                Grid.Column="1"
                                            HorizontalAlignment="Center"
                                                    CornerRadius="20 0 20 0"
                                            Background="{DynamicResource orangeLightLinear}">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Label Content="{lex:Loc Key=cate1}"/>

                                                    <ComboBox Name="cate_combo" MinWidth="150" Grid.Column="1" FontSize="18"
                                                          SelectionChanged="cate_combo_SelectionChanged"
                                                          IsEditable="True">
                                                    </ComboBox>
                                                </Grid>

                                            </Border>

                                            <Border Height="50" Margin="10 0 0 0"  
                                                Grid.Column="2"
                                            HorizontalAlignment="Center"
                                                    CornerRadius="20 0 20 0"
                                            Background="{DynamicResource orangeLightLinear}">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Label Content="{lex:Loc Key=item}"/>

                                                    <ComboBox Name="item_combo" 
                                                          SelectionChanged="user_combo_SelectionChanged"
                                                          IsEditable="True"
                                                          MinWidth="150" Grid.Column="1" FontSize="18">
                                                    </ComboBox>
                                                </Grid>

                                            </Border>

                                            <Border Height="50" Margin="10 0 0 0"  
                                                Grid.Column="3"
                                            HorizontalAlignment="Center"
                                                    CornerRadius="20 0 20 0"
                                            Background="{DynamicResource orangeLightLinear}">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Label Content="{lex:Loc Key=user}"/>

                                                    <ComboBox Name="user_combo" 
                                                          SelectionChanged="user_combo_SelectionChanged"
                                                          IsEditable="True"
                                                          MinWidth="150" Grid.Column="1" FontSize="18">
                                                    </ComboBox>
                                                </Grid>

                                            </Border>

                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1" 
                                        CornerRadius="0 0 20 0"
                                        >
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Height="50" Margin="5"  
                                                Grid.Column="0"
                                            HorizontalAlignment="Stretch"
                                                    CornerRadius="20 0 20 0"
                                            Background="{DynamicResource orangeLightLinear}">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Label Content="{lex:Loc Key=ordering}"/>
                                                    <Border Grid.Column="1" 
                                                        CornerRadius="20"
                                                        Background="{DynamicResource grayLightLinear}">
                                                        <Grid  Margin="5 0 0 0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="auto"/>


                                                            </Grid.ColumnDefinitions>

                                                            <CheckBox Content="{lex:Loc Key=descending}" 
                                                                  Unchecked="desc_checked_check"
                                                                  Checked="desc_checked_check"
                                                                  Name="desc_checked"
                                                                  VerticalAlignment="Center"
                                                                  FontSize="16"
                                                                  Foreground="White"
                                                                  FontFamily="{StaticResource raleway_Bold}" RenderTransformOrigin="0.5,0.5">
                                                                <CheckBox.RenderTransform>
                                                                    <TransformGroup>
                                                                        <ScaleTransform ScaleY="1.5"/>
                                                                        <SkewTransform/>
                                                                        <RotateTransform/>
                                                                        <TranslateTransform/>
                                                                    </TransformGroup>
                                                                </CheckBox.RenderTransform>
                                                            </CheckBox>

                                                            <Border Grid.Column="1" Margin="10 0 0 0"
                                                                Padding="5"
                                                                CornerRadius="20 0 20 0"
                                                                VerticalAlignment="Stretch"
                                                                Background="{DynamicResource blueLightRadial}">
                                                                <Grid VerticalAlignment="Center" Margin="5 0 0 0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <RadioButton Content="{lex:Loc Key=name}" Name="food_name_radio"
                                                                             IsChecked="True"
                                                                             Checked="desc_checked_check"
                                                                  FontSize="16"
                                                                  Foreground="White"
                                                                  FontFamily="{StaticResource raleway_Bold}" RenderTransformOrigin="0.5,0.5">
                                                                        <RadioButton.RenderTransform>
                                                                            <TransformGroup>
                                                                                <ScaleTransform ScaleY="1.5"/>
                                                                                <SkewTransform/>
                                                                                <RotateTransform/>
                                                                                <TranslateTransform/>
                                                                            </TransformGroup>
                                                                        </RadioButton.RenderTransform>
                                                                    </RadioButton>

                                                                    <RadioButton Content="{lex:Loc Key=qty}"  Name="qty_radio"
                                                                             Checked="desc_checked_check"
                                                                             Margin="10 0"
                                                                             Grid.Column="1"
                                                                  FontSize="16"
                                                                  Foreground="White"
                                                                  FontFamily="{StaticResource raleway_Bold}" RenderTransformOrigin="0.5,0.5">
                                                                        <RadioButton.RenderTransform>
                                                                            <TransformGroup>
                                                                                <ScaleTransform ScaleY="1.5"/>
                                                                                <SkewTransform/>
                                                                                <RotateTransform/>
                                                                                <TranslateTransform/>
                                                                            </TransformGroup>
                                                                        </RadioButton.RenderTransform>
                                                                    </RadioButton>

                                                                    <RadioButton Content="{lex:Loc Key=price}" Name="price_radio"
                                                                             Checked="desc_checked_check"
                                                                  FontSize="16"
                                                                             Grid.Column="2"
                                                                  Foreground="White"
                                                                  FontFamily="{StaticResource raleway_Bold}" RenderTransformOrigin="0.5,0.5">
                                                                        <RadioButton.RenderTransform>
                                                                            <TransformGroup>
                                                                                <ScaleTransform ScaleY="1.5"/>
                                                                                <SkewTransform/>
                                                                                <RotateTransform/>
                                                                                <TranslateTransform/>
                                                                            </TransformGroup>
                                                                        </RadioButton.RenderTransform>
                                                                    </RadioButton>


                                                                </Grid>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </Grid>

                                            </Border>

                                            <Border Height="50" Margin="5 0 0 0"  
                                                Grid.Column="2"
                                            HorizontalAlignment="Stretch"
                                                    CornerRadius="20 0 20 0"
                                            Background="{StaticResource orangeLightLinear}">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Label Content="{lex:Loc Key=viewing}"/>

                                                    <Border Grid.Column="1" 
                                                        CornerRadius="20 0 20 0"
                                                        Background="{StaticResource grayLightLinear}">
                                                        <Grid  Margin="5 0 0 0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="auto"/>


                                                            </Grid.ColumnDefinitions>

                                                            <CheckBox Content="{lex:Loc Key=type}" 
                                                                  Checked="desc_checked_check"
                                                                  Unchecked="desc_checked_check"
                                                                  IsChecked="True"
                                                                  Name="type_checked"
                                                                  VerticalAlignment="Center"
                                                                  FontSize="16"
                                                                  Foreground="White"
                                                                  FontFamily="{StaticResource raleway_Bold}" RenderTransformOrigin="0.5,0.5">
                                                                <CheckBox.RenderTransform>
                                                                    <TransformGroup>
                                                                        <ScaleTransform ScaleY="1.5"/>
                                                                        <SkewTransform/>
                                                                        <RotateTransform/>
                                                                        <TranslateTransform/>
                                                                    </TransformGroup>
                                                                </CheckBox.RenderTransform>
                                                            </CheckBox>

                                                            <CheckBox Content="{lex:Loc Key=user}" 
                                                                  Checked="desc_checked_check"
                                                                  Unchecked="desc_checked_check"
                                                                  IsChecked="True"
                                                                  x:Name="user_name_checked"
                                                                  Margin="10 0 0 0"
                                                                  Grid.Column="1"
                                                                  VerticalAlignment="Center"
                                                                  FontSize="16"
                                                                  Foreground="White"
                                                                  FontFamily="{StaticResource raleway_Bold}" RenderTransformOrigin="0.5,0.5">
                                                                <CheckBox.RenderTransform>
                                                                    <TransformGroup>
                                                                        <ScaleTransform ScaleY="1.5"/>
                                                                        <SkewTransform/>
                                                                        <RotateTransform/>
                                                                        <TranslateTransform/>
                                                                    </TransformGroup>
                                                                </CheckBox.RenderTransform>
                                                            </CheckBox>
                                                        </Grid>
                                                    </Border>
                                                </Grid>

                                            </Border>

                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <ListView x:Name="salesListview" Grid.Row="1" 
                                  ItemsSource="{Binding}"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                            <ListView.View>
                                <GridView>


                                    <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                                    DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                                    <GridViewColumn Header="{lex:Loc Key=user}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Path=user_name}" 
                                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{lex:Loc Key=price}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Path=total}" 
                                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{lex:Loc Key=item}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label 
                                                       Foreground="{DynamicResource textColor}"
                                               Width="400">
                                                    <Label.Content>
                                                        <AccessText TextWrapping="Wrap" Text="{Binding Path=food}"/>
                                                    </Label.Content>
                                                </Label>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{lex:Loc Key=qty}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Path=qty}"
                                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{lex:Loc Key=order_type}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Path=order_type}"
                                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>

                        </ListView>

                        <Border 
                                CornerRadius="20"
                                Margin="0 10 0 0"
                                Grid.Row="2">

                            <Grid HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border  Height="40"
                                        Margin="0 0 10 0"
                                                    CornerRadius="20 0 20 0"
                                            Background="{StaticResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Label Content="{lex:Loc Key=number}"/>

                                        <Border CornerRadius="20" 
                                                Grid.Column="1"
                                                Background="{StaticResource grayLightLinear}">
                                            <Label Name="mos_tb" MinWidth="150"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Height="40"
                                                Grid.Column="1"
                                        Margin="0 0 10 0"
                                                    CornerRadius="20 0 20 0"
                                            Background="{StaticResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Label Content="{lex:Loc Key=qty}"/>

                                        <Border CornerRadius="20" 
                                                Grid.Column="1"
                                                Background="{StaticResource grayLightLinear}">
                                            <Label Name="tot_qty_tb" MinWidth="150"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Height="40"
                                                Grid.Column="2"
                                                    CornerRadius="20 0 20 0"
                                            Background="{StaticResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Label Content="{lex:Loc Key=total}"/>

                                        <Border CornerRadius="20" 
                                                Grid.Column="1"
                                                Background="{StaticResource grayLightLinear}">
                                            <Label Name="tot_price_tb" MinWidth="150"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                        
                    </Grid>
                </TabItem>
                <TabItem Background="Transparent" Height="40">
                    <TabItem.Header>
                        <Border MinWidth="100" 
                                CornerRadius="20"
                                 Style="{StaticResource blueLightRadialBorder}">
                            <Label Content="{lex:Loc Key=consumed_qty}" FontSize="20"/>
                        </Border>
                    </TabItem.Header>
                    <ListView x:Name="consumedListview"  Background="{StaticResource subBackground}"
                              ItemsSource="{Binding}"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                        <ListView.View>
                            <GridView>

                                <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                                DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                                <GridViewColumn Header="{lex:Loc Key=qty}">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Label Content="{Binding Path=sum_qty}" 
                                                   Foreground="{DynamicResource textColor}"
                                                       MinWidth="150"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="{lex:Loc Key=item}">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Label 
                                                   Foreground="{DynamicResource textColor}"
                                               MaxWidth="200">
                                                <Label.Content>
                                                    <AccessText TextWrapping="Wrap" Text="{Binding Path=item_name}"/>
                                                </Label.Content>
                                            </Label>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="{lex:Loc Key=price}">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Label Content="{Binding Path=sum_price}" 
                                                   Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </TabItem>
                <TabItem Background="Transparent" Height="40" KeyDown="return_tab_keydown">
                    <TabItem.Header>
                        <Border MinWidth="100" 
                                CornerRadius="20"
                                 Style="{StaticResource blueLightRadialBorder}">
                            <Label Content="{lex:Loc Key=returns}" FontSize="20"/>
                        </Border>
                    </TabItem.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border Height="50" Margin="5 5 5 10"   
                        HorizontalAlignment="Center"
                        CornerRadius="20 20 20 0"
                        Background="{StaticResource orangeLightLinear}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="{lex:Loc Key=date}"/>

                                <DatePicker Name="return_date_dp" SelectedDateChanged="return_date_dp_SelectedDateChanged"
                                            Grid.Column="1" Width="200" Text="Add Date"/>
                                <Label Content="{lex:Loc Key=order_num}" Grid.Column="2" Margin="10 0 0 0"/>
                                <TextBox x:Name="return_order_num_tb" 
                                         PreviewTextInput="return_order_num_tb_PreviewTextInput"
                                         TextChanged="return_order_num_tb_TextChanged" MinWidth="100"
                                         Grid.Column="3"/>

                            </Grid>

                        </Border>

                        <ListView x:Name="returnsListview"  Background="{StaticResource subBackground}"
                                  HorizontalContentAlignment="Stretch"
                                  Grid.Row="1"
                                  ItemsSource="{Binding}"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                            <ListView.View>
                                <GridView>

                                    <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                                    DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                                    <GridViewColumn Header="{lex:Loc Key=order_num}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Path=order_no}" 
                                                       Foreground="{DynamicResource textColor}"
                                                       MinWidth="150"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    
                                    <GridViewColumn Header="{lex:Loc Key=number}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Path=no_food}" 
                                                       Foreground="{DynamicResource textColor}"
                                                       MinWidth="150"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{lex:Loc Key=item}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Path=food}" 
                                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{lex:Loc Key=price}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Path=price}" 
                                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{lex:Loc Key=delete}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource imag_border}" MinWidth="100"
                                                        Grid.Column="3">
                                                    <Image Source="delete.png" Width="40" Height="40"/>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>

                        </ListView>

                        <Grid Grid.Row="2" HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Height="50" Margin="10 5 5 5"   
                                Grid.Row="2"
                        HorizontalAlignment="Left"
                        CornerRadius="20 20 20 0"
                        Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Content="{lex:Loc Key=total}"/>

                                    <TextBox Name="tot_returns_price_tb" MinWidth="150"  IsEnabled="False" Grid.Column="1"/>
                                </Grid>

                            </Border>

                            <Button Click="return_items_btn_click" Content="{lex:Loc Key=return}" Grid.Column="1" 
                                    Style="{StaticResource dangerBtn}"
                                    MinWidth="100" Height="40"
                                        HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem Background="Transparent" Height="40">
                    <TabItem.Header>
                        <Border MinWidth="100" 
                                CornerRadius="20"
                                 Style="{StaticResource blueLightRadialBorder}">
                            <Label Content="{lex:Loc Key=print}" FontSize="20"/>
                        </Border>
                    </TabItem.Header>

                    <Grid HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Border Margin="5 5 0 10"   
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=day}"/>

                                <TextBox MinWidth="70" MaxLength="2" 
                                         PreviewTextInput="return_order_num_tb_PreviewTextInput"
                                         Width="80" Grid.Row="1"/>

                            </Grid>

                        </Border>
                        <Border Margin="5 5 0 10"   
                                Grid.Column="1"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=month}"/>

                                <TextBox MinWidth="70" MaxLength="2" 
                                         PreviewTextInput="return_order_num_tb_PreviewTextInput"
                                         Width="80" Grid.Row="1"/>

                            </Grid>

                        </Border>
                        <Border Margin="5 5 0 10"   
                                Grid.Column="2"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=year}"/>

                                <TextBox MinWidth="100" 
                                         MaxLength="4" 
                                         PreviewTextInput="return_order_num_tb_PreviewTextInput"
                                         Grid.Row="1"/>

                            </Grid>

                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource imag_border}">
                            <Image Width="100" Height="100" Source="printer.png"
                                   MouseDown="print_sales_per_day_md"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource imag_border}">
                            <Image Width="100" Height="100" Source="printer.png"/>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
