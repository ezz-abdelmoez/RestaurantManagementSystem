<UserControl x:Class="SalesManagement.files.controllers.CateController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d" >
    <Border CornerRadius="20" Background="{StaticResource pageBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border BorderBrush="White" BorderThickness="1" 
                    HorizontalAlignment="Center"
                    Margin="5" CornerRadius="20">
                    <StackPanel Grid.Row="1" Orientation="Horizontal">

                        <Border  Margin="5 5 5 10" 
                     Grid.Column="1"
                        HorizontalAlignment="Center"
                        
                        CornerRadius="20 0 20 0"
                        Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="{lex:Loc Key=cate1}" FontSize="20"/>

                                <TextBox Text="" Name="cate_name_tb" Grid.Column="1" 
                                         VerticalAlignment="Center"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                             Width="200"
                                     VerticalContentAlignment="Center"
                             Margin="0 0 10 0"
                                     />



                            </Grid>

                        </Border>

                        <Border  Margin="5 5 5 10"  Grid.Column="1"
                        HorizontalAlignment="Center"
                        Grid.Row="1"
                        CornerRadius="20 0 20 0"
                        Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="{lex:Loc Key=print}" FontSize="20"/>

                                <ComboBox  Grid.Column="1" x:Name="print_place_combo"
                                       SelectedIndex="0"
                                       IsEditable="False"
                                     VerticalContentAlignment="Center"
                             Margin="0 0 10 0"
                                     >
                                </ComboBox>



                            </Grid>

                        </Border>

                        <Border Style="{StaticResource imag_border}"
                    Grid.Column="1" Width="80" Height="80" 
                                Margin="20 0 0 0"
                                Grid.Row="2">
                            <Image MouseDown="save_new_cate_img"
                               ToolTip="{lex:Loc Key=save}"
                            Source="save.png"/>
                        </Border>



                    </StackPanel>
                </Border>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>

                <Border CornerRadius="20 20 0 0"
                        BorderThickness="2" BorderBrush="White">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="40"> 
                            <Button Content="Select"  Width="100"
                            Grid.Column="4" Click="ButtonBase_OnClick"/>

                            <StackPanel Orientation="Horizontal" Name="multiEdit_stackpanel" 
                                        Visibility="Collapsed">
                                <Viewbox Height="25">
                                    <CheckBox Content="Select All" Unchecked="ToggleButton_OnUnchecked" Checked="ToggleButton_OnChecked"></CheckBox>
                                </Viewbox>

                                <Border Style="{StaticResource imag_border}"
                                Margin="10 0"
                                Width="40" Height="40"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Grid.Column="8">
                                    <Image Source="/assets/img/remove.png" ToolTip="Delete"
                                   MouseDown="delete_selected_items_img"/>
                                </Border>

                            </StackPanel>
                        </StackPanel>

                        <Border  Margin="5 5 5 10"  
                         HorizontalAlignment="Right" VerticalAlignment="Center"
                         CornerRadius="20 0 20 0"
                         Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="{lex:Loc Key=search}" FontSize="20"/>

                                <TextBox  Grid.Column="1" x:Name="search_cate_tb" 
                                          VerticalAlignment="Center"
                                      TextChanged="search_cate_tb_TextChanged"
                                     Width="200"
                                     VerticalContentAlignment="Center"
                             Margin="0 0 10 0"
                                     />

                                <Border  
                                    Padding="5" MinWidth="50" Height="50"
                                Grid.Column="2"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                CornerRadius="50"
                                Background="{StaticResource greenDarkLinear}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10"/>
                                    </Border.Effect>

                                    <Label x:Name="cate_count_lb" Content="12" FontSize="20" FontWeight="Bold"/>

                                </Border>

                                <!-- <Border Style="{StaticResource imag_border}" -->
                                <!--         Margin="20 0 0 0" -->
                                <!--         Grid.Column="3"> -->
                                <!--     <Image MouseDown="add_new_cate_img" Width="100" -->
                                <!--        ToolTip="{lex:Loc Key=new}" -->
                                <!--        Height="60" Source="write1.png"/> -->
                                <!-- </Border> -->

                            </Grid>

                        </Border>
                    </Grid>
                </Border>

                <ListView x:Name="listview"  Background="{StaticResource subBackground}"
                          Grid.Row="1"
                          HorizontalContentAlignment="Stretch"
                          ScrollViewer.VerticalScrollBarVisibility="Visible">

                    <ListView.View>
                        <GridView>

                            <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                            DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                            <GridViewColumn Header="{lex:Loc Key=number}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding Path=mos}" 
                                               MinWidth="60" 
                                           FontSize="20" Foreground="{DynamicResource textColor}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="{lex:Loc Key=cate1}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox  Grid.Column="1" Width="200"
                                              KeyDown="change_cate_keydown"
                                                  Text="{Binding cate}"  
                                              AcceptsReturn="True"
                                              TextWrapping="Wrap"
                                             />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="{lex:Loc Key=print}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding Path=place}" 
                                               MinWidth="80" FontSize="20"
                                           Foreground="{DynamicResource textColor}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="{lex:Loc Key=order_num}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox MinWidth="100" 
                                             KeyDown="change_arrnge_keydown"
                                                  Text="{Binding order_no}" 
                                             PreviewTextInput="order_no_tb_changed"
                                              FontSize="20">

                                        </TextBox>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="{lex:Loc Key=delete}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource imag_border}" MinWidth="80"
                                            HorizontalAlignment="Center"
                                            Grid.Column="4">
                                            <Image Source="delete.png"
                                               MouseDown="delete_cate_img"
                                               Width="40" Height="40"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>

                </ListView>
            </Grid>

           
        </Grid>
    </Border>
</UserControl>
