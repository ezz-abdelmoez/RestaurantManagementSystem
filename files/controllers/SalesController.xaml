<UserControl x:Class="SalesManagement.files.controllers.SalesController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
            lex:LocalizeDictionary.DesignCulture="en-US"
            lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
            lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d" 
             KeyDown="UserControl_KeyDown"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="Transparent"
             MinHeight="600"
             MinWidth="1100"
             >
    <FrameworkElement.Resources>
        <!--ListBoxItems style-->
        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Margin" Value="0, 0, 0, 10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="{StaticResource raleway_bold_italic}"/>
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Grid>
                            <Border x:Name="background_lbi"
                                    Width="160"
                                    MinHeight="40"
                                   BorderBrush="Black"
                                            CornerRadius="20"
                                            Background="LightGray">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="5" Color="#FF01579B"/>
                                </Border.Effect>
                            </Border>

                           
                            
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontSize" Value="20"/>
                                <Setter Property="Background" TargetName="background_lbi">
                                    <Setter.Value>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#FF008EFF" Offset="0"/>
                                            <GradientStop Color="#FF213749" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="5" Color="#FF00FF13"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </FrameworkElement.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Border CornerRadius="20" Margin="5, 5, 5, 5" Background="{DynamicResource pageBackground}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid MaxWidth="600">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Vertical" KeyDown="StackPanel_KeyDown">
                        <Border Margin="5" CornerRadius="20, 20, 0, 20"
                                Background="{StaticResource blueDarkRadial}"
                                Padding="5">
                            
                            <TextBox Name="total_qty_lb" IsEnabled="False" Height="40" FontSize="20"
                                     TextChanged="total_qty_lb_TextChanged"
                                     TextAlignment="Center"/>
                        </Border>

                        <Border Margin="10, 0, 10, 0" CornerRadius="20" Background="{DynamicResource subBackground}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Button Click="num_enter_btn_click" Content="1" Style="{StaticResource calcBtn1}" Margin="5"/>
                                <Button Click="num_enter_btn_click" Content="2" Style="{StaticResource calcBtn1}" Margin="5" Grid.Column="1"/>
                                <Button Click="num_enter_btn_click" Content="3" Style="{StaticResource calcBtn1}" Margin="5" Grid.Column="2"/>
                                <Button Click="num_enter_btn_click" Content="4" Style="{StaticResource calcBtn1}" Margin="5" Grid.Row="1"/>
                                <Button Click="num_enter_btn_click" Content="5" Style="{StaticResource calcBtn1}" Margin="5" Grid.Row="1" Grid.Column="1"/>
                                <Button Click="num_enter_btn_click" Content="6" Style="{StaticResource calcBtn1}" Margin="5" Grid.Row="1" Grid.Column="2"/>
                                <Button Click="num_enter_btn_click" Content="7" Style="{StaticResource calcBtn1}" Margin="5" Grid.Row="2" />
                                <Button Click="num_enter_btn_click" Content="8" Style="{StaticResource calcBtn1}" Margin="5" Grid.Row="2" Grid.Column="1"/>
                                <Button Click="num_enter_btn_click" Content="9" Style="{StaticResource calcBtn1}" Margin="5" Grid.Row="2" Grid.Column="2"/>
                                <Button Click="num_enter_btn_click" Content="del" Style="{StaticResource calcBtn1}" Margin="5" Grid.Row="3" />
                                <Button Click="num_enter_btn_click" Content="." Style="{StaticResource calcBtn1}" Margin="5" Grid.Row="3" Grid.Column="1"/>
                                <Button Click="num_enter_btn_click" Content="0" Style="{StaticResource calcBtn1}" Margin="5" Grid.Row="3" Grid.Column="2"/>
                            </Grid>
                        </Border>

                        <Border Margin="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="order_type_combo" SelectedIndex="0" 
                                          Height="40"
                                          Grid.Column="0" HorizontalContentAlignment="Center"
                                          Margin="5, 0, 5, 0">
                                    <ComboBoxItem Content="{lex:Loc Key=take_away}"/>
                                    <ComboBoxItem Content="{lex:Loc Key=hall}"/>
                                    <ComboBoxItem Content="{lex:Loc Key=delivery}"/>
                                    <ComboBoxItem Content="{lex:Loc Key=reservation}"/>
                                </ComboBox>

                                <Grid Grid.Column="1" Visibility="Collapsed" x:Name="sale_order_grid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox x:Name="table_no_combo" 
                                              PreviewTextInput="table_no_combo_PreviewTextInput" 
                                              SelectionChanged="table_no_combo_SelectionChanged"
                                              ItemsSource="{Binding}"
                                              DisplayMemberPath="{Binding table_no}"
                                              SelectedValuePath="{Binding table_no}"
                                          MinWidth="50" Width="70" SelectedIndex="0"
                                              HorizontalContentAlignment="Center">
                                        
                                    </ComboBox>
                                    
                                    <ComboBox x:Name="char_no" Grid.Column="1" MinWidth="50" Width="70" SelectedIndex="0"
                                              HorizontalContentAlignment="Center" ToolTip="Chare number">
                                        <ComboBoxItem Content="1"/>
                                        <ComboBoxItem Content="2"/>
                                        <ComboBoxItem Content="3"/>
                                        <ComboBoxItem Content="4"/>
                                    </ComboBox>

                                    <Button x:Name="finish_table_btn" 
                                            Click="finish_table_btn_Click"
                                            Grid.Column="2" Style="{StaticResource dangerBtn}" Content="{lex:Loc Key=finish}"
                                            FontSize="14"/>
                                </Grid>
                                <Grid Grid.Column="1" Name="dev_order_grid" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="{lex:Loc Key=delv_price}" 
                                           FontFamily="{StaticResource raleway_bold_italic}" FontWeight="Bold"
                                           />
                                    <TextBox x:Name="delv_value_tb" Grid.Column="1" MinWidth="100" MaxWidth="100"/>
                                </Grid>

                            </Grid>
                        </Border>
                    </StackPanel>

                    <Border Padding="5" Grid.Row="1">
                        <StackPanel  Orientation="Vertical">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" >
                                <Button Content="{lex:Loc Key=order}" 
                                        x:Name="orderBtn"
                                        Click="orderBtn_Click"
                                        Width="100" Height="40" 
                                        Margin="0, 0, 20, 0" Style="{StaticResource dangerBtn}"/>
                                <Button Content="{lex:Loc Key=client}" 
                                        x:Name="clientBtn"
                                        Click="clientBtn_Click"
                                        Width="100"
                                        Height="40" Margin="0, 0, 20, 0" Style="{StaticResource dangerBtn}"/>
                            </StackPanel>
                            
                        </StackPanel>

                    </Border>

                    <Grid Grid.Row="2" x:Name="orderFoodScrollViewer" 
                          Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Margin="5 0" Height="40" 
                                Background="{StaticResource orangeLightLinear}"
                                CornerRadius="20 20 0 0"
                                >
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="{lex:Loc Key=notes}"/>
                                <Border CornerRadius="20, 0, 20, 0"   Height="40"
                                            Grid.Column="1">
                                    <TextBox x:Name="notes_tb" Foreground="White" FontSize="18" FontFamily="{StaticResource raleway_Bold}" 
                                            
                                             >

                                    </TextBox>
                                </Border>
                            </Grid>

                        </Border>

                        <ListView x:Name="presalelistview" Grid.Row="1"  Width="500"
                                  Background="{StaticResource subBackground}"
                                  MinHeight="150"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible"
                                  >

                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{lex:Loc Key=number}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Path=no_food}"
                                                       FontFamily="{StaticResource raleway_bold_italic}"
                                                       FontSize="20"
                                                       IsTabStop="{Binding activ}">
                                                    <FrameworkElement.Style>
                                                        <Style>
                                                            <Style.Triggers>
                                                                <Trigger Property="Control.IsTabStop" Value="true">
                                                                    <Setter Property="Control.Background" Value="SteelBlue"/>
                                                                    <Setter Property="Control.Foreground" Value="White"/>
                                                                </Trigger>
                                                                <Trigger Property="Control.IsTabStop" Value="false">
                                                                    <Setter Property="Control.Foreground" Value="Black"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </FrameworkElement.Style>
                                                </Label>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{lex:Loc Key=name}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label 
                                                       Width="200"
                                                       IsTabStop="{Binding Path=activ}"
                                                       FontSize="16" FontWeight="Bold"
                                                       FontFamily="{StaticResource raleway_bold_italic}"
                                                        >
                                                    <!--<Label.Resources>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                                        </Style>
                                                    </Label.Resources>-->
                                                    <Label.Content>
                                                        <AccessText TextWrapping="Wrap" Text="{Binding Path=food}"/>
                                                    </Label.Content>
                                                    <FrameworkElement.Style>
                                                        <Style>
                                                            <Style.Triggers>
                                                                <Trigger Property="Control.IsTabStop" Value="true">
                                                                    <Setter Property="Control.Background" Value="SteelBlue"/>
                                                                    <Setter Property="Control.Foreground" Value="White"/>
                                                                </Trigger>
                                                                <Trigger Property="Control.IsTabStop" Value="false">
                                                                    <Setter Property="Control.Foreground" Value="Black"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </FrameworkElement.Style>
                                                </Label>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{lex:Loc Key=price}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Path=price}"
                                                       IsTabStop="{Binding Path=activ}"
                                                       FontSize="16" FontWeight="Bold"
                                               Width="80">
                                                    <FrameworkElement.Style>
                                                        <Style>
                                                            <Style.Triggers>
                                                                <Trigger Property="Control.IsTabStop" Value="true">
                                                                    <Setter Property="Control.Background" Value="SteelBlue"/>
                                                                    <Setter Property="Control.Foreground" Value="White"/>
                                                                </Trigger>
                                                                <Trigger Property="Control.IsTabStop" Value="false">
                                                                    <Setter Property="Control.Foreground" Value="Black"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </FrameworkElement.Style>
                                                </Label>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{lex:Loc Key=delete}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border  BorderThickness="1" Width="60" CornerRadius="50" Grid.Column="3" 
                                                Style="{StaticResource imag_border}">
                                                    <Image MouseDown="delete_presales_list_items_img_md" Source="delete.png"  Width="30" Height="30" Margin="5"/>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                </GridView>
                            </ListView.View>

                           

                        </ListView>


                    </Grid>


                   
                     <Border Grid.Row="2" Name="clientBorderViewer" Visibility="Collapsed" Width="500"
                            BorderBrush="White" BorderThickness="1" 
                            Background="{StaticResource subBackground}"
                            Margin="5"
                            CornerRadius="20">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="5" BlurRadius="20" Color="{StaticResource shadow1}"/>
                            </Border.Effect>

                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Visibility="Visible" Height="50" CornerRadius="20 20 0 0"
                                    Background="{StaticResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Content="{lex:Loc Key=search_phone}"/>
                                        <Border CornerRadius="20, 0, 20, 0"   Height="50"
                                        Grid.Column="1" >
                                            <TextBox  Name="client_search_tb"
                                                      GotFocus="client_search_tb_GotFocus"
                                                      LostFocus="client_search_tb_LostFocus"
                                                      PreviewTextInput="client_search_tb_PreviewTextInput_1"
                                                  TextChanged="client_search_tb_TextChanged"
                                                 Foreground="White" FontSize="20" FontFamily="{StaticResource raleway_Bold}" 
                                            Background="Transparent" HorizontalContentAlignment="Center" 
                                            VerticalContentAlignment="Center">

                                            </TextBox>
                                        </Border>
                                    </Grid>

                                </Border>

                                <ComboBox Name="client_combo"
                                      SelectionChanged="client_combo_SelectionChanged"
                                      IsEditable="True" Height="40" Grid.Row="1" 
                                      MinHeight="40" Margin="0 5 0 5"/>

                                <Grid Grid.Row="3"
                                  >
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Margin="5 5 5 5" 
                                    CornerRadius="20 20 20 0"
                                    Background="{DynamicResource orangeLightLinear}">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="{lex:Loc Key=name}"/>

                                            <TextBox x:Name="client_name_tb"
                                                     GotFocus="client_search_tb_GotFocus"
                                                      LostFocus="client_search_tb_LostFocus"
                                         TextAlignment="Center"
                                         Grid.Column="1"/>

                                        </Grid>

                                    </Border>

                                    <Border Margin="5" Grid.Row="1"
                                    CornerRadius="20 20 20 0"
                                    Background="{DynamicResource orangeLightLinear}">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="{lex:Loc Key=tel}"/>

                                            <TextBox x:Name="client_tel_tb"
                                                     GotFocus="client_search_tb_GotFocus"
                                                      LostFocus="client_search_tb_LostFocus"
                                         TextAlignment="Center"
                                         Grid.Column="1"/>

                                        </Grid>

                                    </Border>

                                    <Border Margin="5" Grid.Row="2"
                                    CornerRadius="20 20 20 0"
                                    Background="{DynamicResource orangeLightLinear}">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="{lex:Loc Key=email}"/>

                                            <TextBox x:Name="client_email_tb" 
                                                     GotFocus="client_search_tb_GotFocus"
                                                      LostFocus="client_search_tb_LostFocus"
                                         TextAlignment="Center"
                                         Grid.Column="1"/>

                                        </Grid>

                                    </Border>
                                </Grid>
                                <Border Height="40" CornerRadius="20 20 0 0" Grid.Row="4"
                                    Background="{DynamicResource orangeLightLinear}"
                                    Margin="5">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="3*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Content="{lex:Loc Key=address}"/>
                                        <Border CornerRadius="20, 0, 20, 0"   Height="40"
                                        Grid.Column="1">
                                            <TextBox  x:Name="client_address_tb" GotFocus="client_search_tb_GotFocus"
                                                      LostFocus="client_search_tb_LostFocus"/>
                                        </Border>
                                    </Grid>

                                </Border>

                                <ComboBox x:Name="dev_combo" Visibility="Collapsed" Text="Delivery" IsEditable="True" Height="50" Grid.Row="5" MinHeight="40" Margin="0 5 0 20"/>

                                <Grid Grid.Row="6" Margin="0 10 0 0" 
                                  HorizontalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Click="add_new_client_btn_click" Content="{lex:Loc Key=new}"  Height="40" Width="80"
                                        Style="{StaticResource dangerBtn}"
                                        />
                                    <Button Click="update_client_details_btn_click" Content="{lex:Loc Key=update}" 
                                            Style="{StaticResource dangerBtn}" Height="40" 
                                        Grid.Column="1" Width="80" Margin="20 0"/>
                                    <Button Click="delete_client_btn_click" Content="{lex:Loc Key=delete}" 
                                            Grid.Column="2" Height="40" 
                                        Style="{StaticResource dangerBtn1}" Width="80"/>
                                </Grid>
                            </Grid>

                        </Border>
                    

                    <Border Grid.Row="3" 
                            Padding="0 5" CornerRadius="0, 0, 20, 20" 
                            Background="{StaticResource blueDarkRadial}">

                        <StackPanel>
                            <Grid Margin="0 0 0 10" HorizontalAlignment="Center"
                                  Visibility="Visible">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Foreground="Yellow" Content="{lex:Loc Key=discount}" 
                                       RenderTransformOrigin="0.5,0.5">
                                    <UIElement.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform Angle="20.065"/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </UIElement.RenderTransform>
                                </Label>
                                <Border Grid.Column="1" CornerRadius="5" Margin="0,3" Padding="2">
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Checked="discount_checked" Name="Dis0" GroupName="disgrp" Content="0" VerticalAlignment="Center"
                                     Margin="5,0,0,0" VerticalContentAlignment="Center" BorderBrush="Black" BorderThickness="2"
                                     IsChecked="True"/>
                                        <RadioButton Checked="discount_checked"  Name="Dis10" GroupName="disgrp" Content="10"
                                     VerticalAlignment="Center" Margin="5,0,0,0" VerticalContentAlignment="Center" BorderBrush="Black"
                                     BorderThickness="2"/>
                                        <RadioButton Checked="discount_checked" Name="Dis20" GroupName="disgrp" Content="20"
                                     VerticalAlignment="Center" Margin="5,0,0,0" VerticalContentAlignment="Center" BorderBrush="Black"
                                     BorderThickness="2"/>
                                        <RadioButton Checked="discount_checked" Name="Dis25" GroupName="disgrp" Content="25"
                                     VerticalAlignment="Center" Margin="5,0,0,0" VerticalContentAlignment="Center" BorderBrush="Black"
                                     BorderThickness="2"/>
                                        <RadioButton Checked="discount_checked" Name="Dis50" GroupName="disgrp" Content="50"
                                     VerticalAlignment="Center" Margin="5,0,0,0" VerticalContentAlignment="Center" BorderBrush="Black"
                                     BorderThickness="2"/>
                                    </StackPanel>
                                </Border>
                                <Label Grid.Column="2" Foreground="Yellow" Content="%"/>
                            </Grid>
                            <Grid MaxWidth="300" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource imag_border}">
                                    <Image MouseDown="new_order_del_presales_img_md" 
                                           ToolTip="New Order F11" Source="cut.png" Width="50" Height="50"/>
                                </Border>
                                <Border Margin="10, 2" MinWidth="150" Grid.Column="1"
                                    Background="{StaticResource orangeDeepRadial}"
                                    CornerRadius="20">

                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="5"
                                                      Color="Gray" 
                                                      BlurRadius="10" Direction="100"/>
                                    </Border.Effect>
                                    <Label x:Name="final_tot_price_tb" FontSize="25"/>

                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource imag_border}">
                                    <Image MouseDown="save_bill_img_click" 
                                           ToolTip="Save F12"
                                           Source="1362753193_whack_totalcommander.png" Width="50" Height="50" />
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Click="show_all_food_btn_click" Content="{lex:Loc Key=all}"
                            Style="{StaticResource dangerBtn1}" Height="50"/>

                    <Border Grid.Row="1" Margin="10" MinWidth="150"
                            Padding="5"
                            MaxWidth="200"
                            CornerRadius="20"
                            Background="{DynamicResource subBackground}">
                        <Border.Effect>
                            <DropShadowEffect Color="{StaticResource shadow1}" ShadowDepth="10"
                                              BlurRadius="20"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"></RowDefinition>
                                <RowDefinition Height="*"></RowDefinition>
                            </Grid.RowDefinitions>

                            <Viewbox>
                                <CheckBox Content="Image" Name="showImgsCheck" IsChecked="True"
                                         ></CheckBox>
                            </Viewbox>

                            <ListBox x:Name="cate_listbox"  Grid.Row="1"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionChanged="cate_listbox_SelectionChanged"
                                     FontWeight="Bold"
                                     ItemsSource="{Binding}"
                                     FontSize="20">

                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel IsItemsHost="true" 
                                                                Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>


                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Food layout-->
                <Border Grid.Column="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <WrapPanel>

                            <TextBox x:Name="barcode_search_tb" Width="120" 
                                     MaxWidth="200" Height="40" MaxLines="5"/>


                            <ComboBox x:Name="cate_combo"  
                                      Text="Category"
                                      SelectionChanged="cate_combo_SelectionChanged"
                                      IsEditable="True"
                                      Margin="5 0 0 0" ToolTip="{lex:Loc Key=items}">

                            </ComboBox>
                            <ComboBox x:Name="items_combo" SelectedIndex="0"
                                      Text="Item"
                                      ItemsSource="{Binding}"
                                       IsEditable="True"
                                      Grid.Column="2"
                                      SelectionChanged="items_combo_SelectionChanged"
                                      Margin="5 0 0 0" ToolTip="Categories">

                            </ComboBox>

                            <Label Content="{lex:Loc Key=exist}" Grid.Column="3" Foreground="{DynamicResource textColor}" 
                                   Margin="10 0 0 0"
                                   FontWeight="Bold" RenderTransformOrigin="0.5,0.5">
                                <Label.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform Angle="-45"/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Label.RenderTransform>
                                <Label.Effect>
                                    <DropShadowEffect Color="#FF187603"/>
                                </Label.Effect>
                            </Label>
                            <TextBox x:Name="exist_qty_tb" IsEnabled="False" 
                                     Width="100" Height="40" Grid.Column="4"/>
                            <Label Content="{lex:Loc Key=price}" Grid.Column="5" 
                                   Foreground="{DynamicResource textColor}"
                                   Margin="10 0 0 0"
                                   FontWeight="Bold" RenderTransformOrigin="0.5,0.5">
                                <Label.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform Angle="-45"/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </Label.RenderTransform>
                                <Label.Effect>
                                    <DropShadowEffect Color="#FF187603"/>
                                </Label.Effect>
                            </Label>
                            <TextBox x:Name="price_tb" IsEnabled="False" Width="100" Height="40" Grid.Column="6"
                                     PreviewTextInput="price_tb_PreviewTextInput">
                               
                            </TextBox>
                            <TextBox x:Name="total_price_tb" Margin="10" Width="100" Height="40" Grid.Column="7">
                                
                            </TextBox>

                            <Border Style="{StaticResource imag_border}"
                                    Margin="5"
                                    Height="50">
                                <Image Source="/assets/img/refresh-button.png"
                                       MouseDown="refresh_page_md"></Image>
                            </Border>

                        </WrapPanel>

                        <Border 
                                Grid.Row="1">
                            <ListView  x:Name="foodListView"
                                       SelectionChanged="foodListView_SelectionChanged"
                                       ItemsSource="{Binding}"
                                       ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                       ScrollViewer.CanContentScroll="False"
                                       ScrollViewer.IsDeferredScrollingEnabled="False"
                                       VirtualizingStackPanel.IsVirtualizing="True">

                                
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>

                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Button 
                                            Click="food_selected_btn_click"
                                            Style="{StaticResource calcBtn1}"
                                             Margin="2.5"
                                            BorderThickness="0" 
                                            Height="auto"
                                            Cursor="Hand"
                                            >
                                            <StackPanel>
                                                <Image x:Name="food_image" Source="{Binding food_img, 
                                                    Converter={StaticResource MyConverter}, 
                                                    ConverterParameter=0}" Width="150"></Image>
                                                <Grid HorizontalAlignment="Center">

                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock
                                                    Margin="5"
                                                    FontSize="18"
                                                    FontFamily="{DynamicResource raleway_Bold}"
                                                    Text="{Binding food}"
                                                    FontWeight="Bold"
                                                    Grid.Row="0"
                                                    HorizontalAlignment="Center"
                                                    TextAlignment="Center"
                                                    TextWrapping="Wrap"
                                                    />
                                                    <StackPanel
                                                    HorizontalAlignment="Center"
                                                    Orientation="Horizontal"
                                                    Grid.Row="1"
                                                    >
                                                        <TextBlock FontWeight="Bold" 
                                                       Foreground="Brown" 
                                                       FontSize="24" 
                                                       Text="{Binding price}"
                                                               TextWrapping="Wrap"
                                                       />
                                                        <TextBlock Text="(" 
                                                       Margin="5,0,0,0" 
                                                       FontWeight="Bold" 
                                                       Grid.Row="0" 
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center" 
                                                       TextWrapping="Wrap"/>
                                                        <TextBlock Margin="2,0,0,0" 
                                                       FontWeight="Bold" 
                                                       Grid.Row="0" 
                                                               Foreground="Green"
                                                       Text="{Binding letter}"
                                                       HorizontalAlignment="Center" 
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" 
                                                       />
                                                        <TextBlock 
                                                        Text=")" 
                                                        Margin="0,0,0,0" 
                                                        FontWeight="Bold" 
                                                        Grid.Row="0" 
                                                        HorizontalAlignment="Center"
                                                               TextAlignment="Center" 
                                                        TextWrapping="Wrap"/>

                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ListView.ItemTemplate>

                            </ListView>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>


        <!-- Bottom listview -->
        <Border VerticalAlignment="Bottom" Grid.Row="1" Background="#BCAEAEAE" Height="60" Margin="5" 
                Visibility="Collapsed" Name="tables_lv_border"
                CornerRadius="20">
            <ListView x:Name="tables_lv"  SelectedIndex="0" 
                      SelectionChanged="tables_lv_SelectionChanged"
                      Background="Transparent"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top" ItemsSource="{Binding}">
                
                
                
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"  IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border MinWidth="40" CornerRadius="20" Padding="5" 
                                Background="{Binding Path=used, Converter={StaticResource checkTables}}">
                            <Label Content="{Binding table_no}"/>
                        </Border>
                       
                    </DataTemplate>
                </ListView.ItemTemplate>


            </ListView>
        </Border>


    </Grid>
</UserControl>
