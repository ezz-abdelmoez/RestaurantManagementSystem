<UserControl x:Class="SalesManagement.files.controllers.OrdersController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
            lex:LocalizeDictionary.DesignCulture="en-US"
            lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
            lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d" >


    <Grid Background="{DynamicResource pageBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25*"></ColumnDefinition>
            <ColumnDefinition Width="75*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

         <ListView x:Name="summaryListView" Grid.Row="2" 
                  SelectionChanged="SummaryListView_OnSelectionChanged"
                                  HorizontalContentAlignment="Stretch"
                                  ItemsSource="{Binding}"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                <ListView.View>
                    <GridView>

                        <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                        DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                        <GridViewColumn Header="{lex:Loc Key=order}"> 
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=order_no}" 
                                           Foreground="{DynamicResource textColor}"
                                           Width="80" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=qty}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=tot_qty}" 
                                               Foreground="{DynamicResource textColor}"
                                               MinWidth="150" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=price}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=tot_price}" 
                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>


                    </GridView>
                </ListView.View>



            </ListView>  

        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <ComboBox Name="order_no_combo" Visibility="Hidden"/>

            <Border Background="{StaticResource subBackground}"
                Padding="5" >

                <Grid VerticalAlignment="Center"
                  FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource imag_border}"
                            Margin="5">
                        <Image MouseDown="get_order_no_less_img_md" Source="back.png"/>
                    </Border>

                    <TextBox x:Name="max_order_tb" Grid.Column="1" Width="150" Height="50" />

                    <Border Grid.Column="2" Style="{StaticResource imag_border}"
                            Margin="5">
                        <Image MouseDown="get_order_no_bigger_img_md" Source="forward.png" />
                    </Border>

                    <Border Grid.Column="3" 
                           >
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>



                            <ComboBox Name="order_type_combo"  Margin="0 5"
                                  SelectedIndex="0">
                                <ComboBoxItem Content="{lex:Loc Key=all}"/>
                                <ComboBoxItem Content="{lex:Loc Key=take_away}"/>
                                <ComboBoxItem Content="{lex:Loc Key=hall}"/>
                                <ComboBoxItem Content="{lex:Loc Key=delivery}"/>
                                <ComboBoxItem Content="{lex:Loc Key=reservation}"/>
                            </ComboBox>

                            <Grid Grid.Column="1" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>

                                <Border   Margin="10 0 0 0 "  HorizontalAlignment="Left"
                            CornerRadius="20 20 0 0" Background="{StaticResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto"/>
                                            <RowDefinition Height="auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Content="{lex:Loc Key=day}"/>
                                        <TextBox x:Name="day_tb" 
                                             PreviewTextInput="year_tb_PreviewTextInput"
                                             MaxLength="2" Grid.Row="1" 
                                             MinWidth="60" MaxWidth="80">

                                        </TextBox>
                                    </Grid>

                                </Border>

                                <Border Grid.Column="1" Margin="5 0"  HorizontalAlignment="Left"
                                CornerRadius="20 20 0 0" Background="{StaticResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto"/>
                                            <RowDefinition Height="auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Content="{lex:Loc Key=month}"/>
                                        <TextBox x:Name="month_tb" 
                                             PreviewTextInput="year_tb_PreviewTextInput"
                                             MaxLength="2" Grid.Row="1" MinWidth="60" MaxWidth="80">

                                        </TextBox>
                                    </Grid>

                                </Border>

                                <Border   Margin="0 0 0 0" Grid.Column="2"  HorizontalAlignment="Left"
                            CornerRadius="20 20 0 0" Background="{StaticResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto"/>
                                            <RowDefinition Height="auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Content="{lex:Loc Key=year}"/>
                                        <TextBox x:Name="year_tb" 
                                             PreviewTextInput="year_tb_PreviewTextInput"
                                             MaxLength="4" Grid.Row="1"
                                             MinWidth="80" MaxWidth="80">

                                        </TextBox>
                                    </Grid>

                                </Border>

                            </Grid>

                            <ComboBox Name="admin_combo" 
                                  ItemsSource="{Binding}"
                                  IsEditable="True"
                                  Grid.Column="2"  Margin="0 5">
                            </ComboBox>

                            <Border Style="{StaticResource imag_border}"
                                    Grid.Column="3"
                                    Margin="5"
                                    Height="50">
                                <Image Source="/assets/img/refresh-button.png"
                                       MouseDown="refresh_page_md"></Image>
                            </Border>
                        </Grid>
                    </Border>

                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="5" Padding="5" Background="{StaticResource pageBackground}" 
                CornerRadius="20">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="10" BlurRadius="20" Color="{StaticResource shadow1}"/>
                </Border.Effect>
                <StackPanel Orientation="Vertical" VerticalAlignment="Center"
                        HorizontalAlignment="Left">
                    <Border Margin="5 0 0 5"   HorizontalAlignment="Left" Height="50"
                        CornerRadius="20 20 0 0" Background="{StaticResource greenDarkLinear}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="{lex:Loc Key=date}"/>
                            <TextBox x:Name="ord_date_tb" Grid.Column="1" IsEnabled="False" 
                                     />
                        </Grid>

                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Height="50" Margin="5 0 30 0" 
                        CornerRadius="20 20 0 0" Background="{StaticResource greenDarkLinear}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="{lex:Loc Key=order_type}"/>
                                <TextBox x:Name="order_type_tb"  Grid.Column="1" IsEnabled="False"
                                     />
                            </Grid>

                        </Border>
                        <Border Height="50" Margin="5" Grid.Column="1"
                        CornerRadius="20 20 0 0" Background="{StaticResource greenDarkLinear}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>
                                <Label Content="{lex:Loc Key=user}"/>
                                <Border CornerRadius="20, 0, 20, 0"  
                                        Grid.Column="1" Background="{StaticResource orangeLightLinear}">
                                    <TextBox x:Name="order_user_tb" IsEnabled="False"
                                     >

                                    </TextBox>
                                </Border>
                            </Grid>

                        </Border>
                    </Grid>


                </StackPanel>
            </Border>


            <ListView x:Name="ordersListview" Grid.Row="2" 
                  SelectionChanged="ordersListview_SelectionChanged"
                                  HorizontalContentAlignment="Stretch"
                                  ItemsSource="{Binding}"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                <ListView.View>
                    <GridView>

                        <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                        DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                        <GridViewColumn Header="{lex:Loc Key=qty}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=no_food}" 
                                               Foreground="{DynamicResource textColor}"
                                               MinWidth="150" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=item}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label 
                                       Foreground="{DynamicResource textColor}"
                                               Width="300" >
                                        <Label.Content>
                                            <AccessText TextWrapping="Wrap" Text="{Binding Path=food}"/>
                                        </Label.Content>
                                    </Label>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=price}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=price}" 
                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>


                    </GridView>
                </ListView.View>



            </ListView>

            <Border  Grid.Row="3" 
                    CornerRadius="0 0 20 20">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">


                    <Border CornerRadius="10" Background="{StaticResource orangeDeepRadial}" Padding="10 5"
                        Margin="5">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="10" BlurRadius="20" Color="{StaticResource shadow1}"/>
                        </Border.Effect>
                        <Label Name="tot_price_order_lb" HorizontalAlignment="Center" VerticalAlignment="Center"  
                           MinWidth="100" Height="50" MaxWidth="400"
                           Style="{StaticResource pageTitle}"/>
                    </Border>


                </Grid>
            </Border>
        </Grid>
    </Grid>


</UserControl>
