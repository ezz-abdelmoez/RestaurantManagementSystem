<UserControl x:Class="SalesManagement.files.controllers.SpendsController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             mc:Ignorable="d" >
    <Border Background="#B2D9D9D9"
            CornerRadius="20" Padding="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Border>
                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Left"
                            CornerRadius="20 0 20 0"
                            Background="{DynamicResource blueDarkRadial}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Employee"/>

                            <ComboBox MinWidth="200" IsEditable="True"
                                      Height="50"
                                      Grid.Column="1"/>

                        </Grid>

                    </Border>

                    <Border Margin="5 5 5 10"   
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource blueDarkRadial}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="Month"/>

                            <TextBox MinWidth="80" Grid.Row="1" MaxWidth="80"/>

                        </Grid>

                    </Border>

                    <Border Margin="5 5 5 10"   
                            Grid.Column="3"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource blueDarkRadial}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="Year"/>

                            <TextBox Width="80" Grid.Row="1"/>

                        </Grid>

                    </Border>
                    
                </Grid>
            </Border>

            <Border Margin="5 5 5 10"   Grid.Row="1"
                    Padding="5"
                            HorizontalAlignment="Stretch"
                            CornerRadius="20 0 20 0"
                            Background="{DynamicResource greenDarkLinear}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Margin="5 5 5 10"  
                            HorizontalAlignment="Center"
                            CornerRadius="20 0 20 0"
                            Background="{DynamicResource orangeDeepRadial}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="Date"/>

                            <DatePicker MinWidth="150" 
                                        Text="Add Date"
                                        MinHeight="50"
                                        Grid.Row="1"/>

                        </Grid>

                    </Border>

                    <Border Margin="5 5 5 10"  Grid.Column="1"
                            HorizontalAlignment="Center"
                            CornerRadius="20 0 20 0"
                            Background="{DynamicResource orangeDeepRadial}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="Value"/>

                            <TextBox MinWidth="150" 
                                        MinHeight="50"
                                        Grid.Row="1"/>

                        </Grid>

                    </Border>

                    <Border Margin="5 5 5 10"  Grid.Column="2"
                            HorizontalAlignment="Center"
                            CornerRadius="20 0 20 0"
                            Background="{DynamicResource orangeDeepRadial}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="Description"/>

                            <ComboBox MinWidth="150" 
                                      FontSize="18"
                                        MinHeight="50"
                                        Grid.Row="1">
                                <ComboBoxItem Content="Salary"/>
                                <ComboBoxItem Content="Spend"/>
                            </ComboBox>

                        </Grid>

                    </Border>

                    <Border Margin="5 5 5 10"  Grid.Column="3"
                            HorizontalAlignment="Center"
                            CornerRadius="20 0 20 0"
                            Background="{DynamicResource orangeDeepRadial}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="Notes"/>

                            <TextBox MinWidth="250" 
                                        MinHeight="50"
                                        Grid.Row="1"/>

                        </Grid>

                    </Border>

                    <Button Content="Add" Width="150" Height="50" Grid.Column="4"
                            Margin="10 0 10 0"
                            Style="{StaticResource calcBtn}"/>

                </Grid>
            </Border>

            <ListView x:Name="listview"  Background="Transparent" Grid.Row="2"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                <ListView.View>
                    <GridView>
                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="Amount" 
                                            MinHeight="50"
                                            MinWidth="100" 
                                            Style="{StaticResource dangerBtn}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=amount}" 
                                               Foreground="Black"
                                               MinWidth="100" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="Description" 
                                            MinHeight="50"
                                            MinWidth="110" 
                                            Style="{StaticResource dangerBtn}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=desc}" 
                                               Foreground="Black"
                                               MinWidth="110" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="Notes" 
                                            MinHeight="50"
                                            MinWidth="150" 
                                            Style="{StaticResource dangerBtn}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=notes}" 
                                               Foreground="Black"
                                               MinWidth="150" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="Sale Date" 
                                            MinHeight="50"
                                            MinWidth="150" 
                                            Style="{StaticResource dangerBtn}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=sale_date}" 
                                               Foreground="Black"
                                               MinWidth="150" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="Delete" 
                                            MinHeight="50"
                                            MinWidth="100" 
                                            Style="{StaticResource dangerBtn}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border HorizontalAlignment="Center" 
                                            Style="{StaticResource imag_border}">
                                        <Image Width="50" Height="50" Source="delete.png"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>

            </ListView>

            <Border Background="{StaticResource greenDarkLinear}"
                        Margin="5"
                        Grid.Row="3"
                    VerticalAlignment="Bottom"
                        MinHeight="70"
                        MinWidth="100"
                        CornerRadius="20">

                <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Left"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource blueDarkRadial}">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Total"/>

                        <TextBox IsEnabled="False" MinWidth="150" Grid.Column="1"/>

                    </Grid>

                </Border>


            </Border>

        </Grid>
    </Border>
</UserControl>
