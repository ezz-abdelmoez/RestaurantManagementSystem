<UserControl x:Class="SalesManagement.files.controllers.StoreController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d" >
    <Border CornerRadius="20" Background="{DynamicResource pageBackground}"
            HorizontalAlignment="Center">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Border CornerRadius="20 20 0 0"
                    Background="{StaticResource greenDarkLinear}">
                <Grid>
                    
                    <Label Content="{lex:Loc Key=store}" Style="{StaticResource pageTitle}"
                           HorizontalAlignment="Center"/>

                    
                    <Border Style="{StaticResource imag_border}"
                            HorizontalAlignment="Right"
                            Margin="5"
                            Height="50">
                        <Image Source="/assets/img/refresh-button.png"
                               MouseDown="refresh_page_md"></Image>
                    </Border>

                </Grid>


            </Border>

            <Border  Margin="10"  Grid.Row="1" 
                     Padding="5"
                        HorizontalAlignment="Center"
                        CornerRadius="20"
                        Background="{DynamicResource pageBackground}">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="5" BlurRadius="20" Color="{DynamicResource shadow1}"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lex:Loc Key=search}" FontSize="20" 
                             Foreground="{DynamicResource textColor}"/>

                    <TextBox x:Name="search_tb" Text="" Grid.Column="1"
                             VerticalAlignment="Center"
                             TextChanged="search_tb_TextChanged"
                             MinWidth="200" MaxWidth="300"
                                     VerticalContentAlignment="Center"
                             Margin="0 0 10 0"
                                     />

                    <Border  
                                    Padding="5"
                                Grid.Column="4"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=department}"/>

                            <ComboBox x:Name="search_store_item_combo" Grid.Row="1"
                                      SelectionChanged="search_store_item_combo_SelectionChanged"
                                      IsEditable="True"
                                      Margin="0 0 10 0">
                            </ComboBox>
                            
                        </Grid>
                    </Border>

                </Grid>

            </Border>

            <Grid Grid.Row="2" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <ListView x:Name="storeItemListview"  Background="{DynamicResource subBackground}"
                          SelectionChanged="StoreItemListview_OnSelectionChanged"
                                  HorizontalContentAlignment="Stretch"
                          MinHeight="200"
                          ItemsSource="{Binding}"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">
                    <ListView.View>
                        <GridView>

                            <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                            DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                            <GridViewColumn Header="{lex:Loc Key=cate1}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label   Width="200"
                                                 Foreground="{DynamicResource textColor}"
                                                 >
                                            <Label.Content>
                                                <AccessText TextWrapping="Wrap" Text="{Binding Path=item_name}"/>
                                            </Label.Content>
                                        </Label>
                                        
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="{lex:Loc Key=delete}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource imag_border}"
                                                Grid.Column="1"
                                                Width="40" Height="40"
                                                >
                                            <Image MouseDown="delete_item_store_btn"  Source="delete.png"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
         

                </ListView>

                <Border Grid.Column="1" 
                        CornerRadius="20"
                        MinWidth="300">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border CornerRadius="20 20 0 0"
                                Background="{DynamicResource blueDarkRadial}"
                                Height="40">
                            <Grid>
                                <Button  Style="{StaticResource dangerBtn1}"
                                        MinWidth="60" Click="show_new_store_item_border"
                                        Content="{lex:Loc Key=new}" HorizontalAlignment="Left"/>
                                <Label Content="{lex:Loc Key=edit_cate}" HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>

                        

                        <WrapPanel Grid.Row="1" >

                            <Border Margin="5 5 5 10" 
                                Grid.Row="1"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Content="{lex:Loc Key=department}" Grid.ColumnSpan="2"/>

                                    <ComboBox x:Name="edit_store_item_combo" 
                                              IsEditable="True" Grid.Row="1">
                                    </ComboBox>

                                    <TextBox MaxWidth="300"
                                         Visibility="Collapsed"
                                          MinHeight="50"
                                      FontSize="18"
                                      MinWidth="150" Grid.Row="1">
                                    </TextBox>

                                    
                                </Grid>
                            </Border>
                            
                            <Border  
                                    Padding="5"
                                Margin="5"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=item}"/>

                                    <TextBox x:Name="edit_name_tb"  Grid.Row="1"
                                      Height="40"
                                      Margin="0 0 10 0">
                                    </TextBox>

                                </Grid>
                            </Border>

                            <Border  
                                    Padding="5"
                                    Margin="5"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=qty}"/>

                                    <TextBox x:Name="edit_qty_tb"  Grid.Row="1"
                                             PreviewTextInput="edit_qty_tb_PreviewTextInput"
                                              MinWidth="100"
                                      Height="40"
                                      Margin="0 0 10 0">
                                    </TextBox>

                                </Grid>
                            </Border>

                            <Border  
                                    Padding="5"
                                Margin="5"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=minimum}"/>

                                    <TextBox x:Name="edit_min_tb"  Grid.Row="1"
                                             PreviewTextInput="edit_qty_tb_PreviewTextInput"
                                              MinWidth="100"
                                      Height="40"
                                      Margin="0 0 10 0">
                                    </TextBox>

                                </Grid>
                            </Border>

                            <Border Style="{StaticResource imag_border}"
                                Margin="10"
                                >
                                <Image MouseDown="edit_item_store_image"
                                       Width="80" Height="80" Source="save.png"/>

                            </Border>

                        </WrapPanel>



                        <Border 
                                Grid.Row="2"
                                Margin="10"
                                CornerRadius="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Margin="10 0"
                                        CornerRadius="20"
                                        Background="{DynamicResource pageBackground}"
                                        BorderThickness="1" BorderBrush="White">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <ComboBox Name="en_leave_combo"
                                                  Margin="5 0"
                                                  IsEditable="False" SelectedIndex="0">
                                            <ComboBoxItem Content="{lex:Loc Key=enter}"/>
                                            <ComboBoxItem Content="{lex:Loc Key=exit}"/>
                                        </ComboBox>

                                        <Border  
                                            Margin="5 0"
                                            Grid.Column="1"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            CornerRadius="20 20 20 0"
                                            Background="{DynamicResource orangeLightLinear}">

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="auto"/>
                                                </Grid.RowDefinitions>
                                                <Label Content="{lex:Loc Key=qty}"/>

                                                <TextBox Name="en_leave_qty_tb" Grid.Row="1"
                                                         PreviewTextInput="edit_qty_tb_PreviewTextInput"
                                                    MinWidth="100"
                                                  Height="40">
                                                </TextBox>

                                            </Grid>
                                        </Border>

                                        <Border  
                                            Padding="5"
                                            Margin="5"
                                            Grid.Column="2"
                                            HorizontalAlignment="Center"
                                            CornerRadius="20 20 20 0"
                                            Background="{DynamicResource orangeLightLinear}">

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <Label Content="{lex:Loc Key=date}"/>

                                                <DatePicker Name="en_leave_date"  Grid.Row="1"
                                                    MinWidth="150"
                                                  Height="40"
                                                  FontSize="16"
                                                  Margin="0 0 10 0">
                                                </DatePicker>

                                            </Grid>
                                        </Border>

                                        <Button Grid.Column="3" 
                                                Click="register_enter_learve_btn"
                                                Margin="10 0"
                                                MinWidth="100"
                                                Height="50"
                                                Style="{StaticResource dangerBtn}"
                                                Content="{lex:Loc Key=register}"/>

                                    </Grid>
                                </Border>

                                <ListView x:Name="storeActionListview" Grid.Row="1"  Background="{DynamicResource subBackground}"
                                  HorizontalContentAlignment="Stretch"
                                          MinHeight="150"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible" ItemsSource="{Binding}">
                                    <ListView.View>
                                        <GridView>

                                            <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                                            DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                                            <GridViewColumn Header="{lex:Loc Key=date}">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Label Content="{Binding Path=act_date}" 
                                                               Foreground="{DynamicResource textColor}"
                                                               MinWidth="150" />
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>

                                            <GridViewColumn Header="{lex:Loc Key=type}">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Label Content="{Binding Path=act_txt}"
                                                               Foreground="{DynamicResource textColor}"
                                                                MinWidth="150" Padding="5" FontSize="20"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>

                                            <GridViewColumn Header="{lex:Loc Key=qty}"> 
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Label Content="{Binding Path=act_qty}" 
                                                               Foreground="{DynamicResource textColor}"
                                                               MinWidth="150"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>

                                            <GridViewColumn Header="{lex:Loc Key=remaining}">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Label Content="{Binding Path=remain}" 
                                                               Foreground="{DynamicResource textColor}"
                                                               MinWidth="150"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>

                                            <GridViewColumn>
                                                <GridViewColumn.Header>
                                                    <TextBox Text="5" Name="action_num_view_tb"
                                                             PreviewTextInput="action_num_view_tb_PreviewTextInput"
                                                             TextChanged="action_num_view_tb_TextChanged"/>
                                                </GridViewColumn.Header>
                                            </GridViewColumn>


                                        </GridView>
                                    </ListView.View>
                                </ListView>

                            </Grid>
                        </Border>
                        
                    </Grid>
                    
                </Border>

            </Grid>

            <Border CornerRadius="20" Grid.Row="3"
                    Height="60">
                
                <Border   Margin="10 0"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Grid.Row="1"
                        CornerRadius="20 0 20 0"
                        Background="{DynamicResource orangeLightLinear}">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="{lex:Loc Key=number}" FontSize="20"/>

                        <TextBox  Grid.Column="1" MinWidth="100" Name="tot_tb"
                                  IsEnabled="False"
                                  MaxWidth="150"
                             Margin="0 0 10 0"
                                     />

                        

                    </Grid>

                </Border>

                

            </Border>

            <Border x:Name="border_add_new_store_item"  Visibility="Collapsed"
                    Grid.RowSpan="5"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

                <Border HorizontalAlignment="Center"
                        CornerRadius="20"
                           VerticalAlignment="Center"
                        Padding="10" Style="{StaticResource blueLightRadialBorder}">
                    <Border.Effect>
                        <DropShadowEffect Color="Gray" ShadowDepth="20"
                                          BlurRadius="20"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource imag_border}" 
                                HorizontalAlignment="Left"
                                Margin="0 0 0 10"
                                Width="50" Height="50" 
                                >
                            <Image MouseDown="hide_new_store_item_border" 
                                   Source="delete.png"/>

                        </Border>
                        <WrapPanel Grid.Row="1">

                            <Border Margin="5 5 5 10" 
                                Grid.Row="1"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Label Content="{lex:Loc Key=department}" Grid.ColumnSpan="2"/>

                                    <ComboBox x:Name="new_store_item_combo" MaxWidth="300"
                                          MinHeight="50"
                                              IsEditable="True"
                                      FontSize="18"
                                      MinWidth="150" Grid.Row="1">
                                    </ComboBox>

                                    <TextBox MaxWidth="300"
                                         Visibility="Collapsed"
                                          MinHeight="50"
                                      FontSize="18"
                                      MinWidth="150" Grid.Row="1">
                                    </TextBox>

                                   
                                </Grid>
                            </Border>

                            <Border  
                                    Padding="5"
                                Margin="5"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=item}"/>

                                    <TextBox x:Name="new_name_tb"  Grid.Row="1"
                                      Height="50"
                                      FontSize="18"
                                      Margin="0 0 10 0">
                                    </TextBox>

                                </Grid>
                            </Border>

                            <Border  
                                    Padding="5"
                                    Margin="5"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=price}"/>

                                    <TextBox x:Name="new_price_tb"  Grid.Row="1"
                                              MinWidth="100"
                                      Height="50"
                                      FontSize="18"
                                      Margin="0 0 10 0">
                                    </TextBox>

                                </Grid>
                            </Border>

                            <Border  
                                    Padding="5"
                                    Margin="5"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=qty}"/>

                                    <TextBox x:Name="new_qty_tb"  Grid.Row="1"
                                              MinWidth="100"
                                      Height="50"
                                      FontSize="18"
                                      Margin="0 0 10 0">
                                    </TextBox>

                                </Grid>
                            </Border>

                            <Border  
                                    Padding="5"
                                Margin="5"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=minimum}"/>

                                    <TextBox x:Name="new_min_tb"  Grid.Row="1"
                                              MinWidth="100"
                                      Height="50"
                                      FontSize="18"
                                      Margin="0 0 10 0">
                                    </TextBox>

                                </Grid>
                            </Border>

                            

                        </WrapPanel>
                        <Border Grid.Row="2" 
                            Style="{StaticResource imag_border}"
                                Margin="0 10 0 0"
                                Width="100" Height="100" 
                                >
                            <Image MouseDown="save_new_item_store_image" Source="save.png"/>

                        </Border>
                    </Grid>
                </Border>


            </Border>

        </Grid>
    </Border>
</UserControl>
