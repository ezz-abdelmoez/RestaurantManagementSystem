<UserControl x:Class="SalesManagement.files.controllers.SafeController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d" Width="800">
    <Border CornerRadius="20" Background="{DynamicResource pageBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Border  
                    CornerRadius="20 20 0 0"
                    Background="{StaticResource greenDarkLinear}">
                <Grid>
                    <Label Content="{lex:Loc Key=safe}" Style="{StaticResource pageTitle}"/>
                    <Image Width="50" Height="50" Source="safe.png"
                           Margin="20 0 0 0"
                           HorizontalAlignment="Left"/>

                    <Border Style="{StaticResource imag_border}"
                            HorizontalAlignment="Right"
                            Margin="5"
                            Height="50">
                        <Image Source="/assets/img/refresh-button.png"
                               MouseDown="refresh_page_md"></Image>
                    </Border>
                </Grid>
                
            </Border>

            <Border Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Margin="5 5 5 10"   
                        Grid.Row="1"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=year}"/>

                            <TextBox Name="year_tb" MaxWidth="400"
                                     MaxLength="4"
                                      FontSize="18"
                                     Text="2022"
                                     PreviewTextInput="month_tb_PreviewTextInput"
                                     TextAlignment="Center"
                                      MinWidth="100" Grid.Row="1">
                            </TextBox>
                        </Grid>
                    </Border>

                    <Border Margin="5 5 5 10"   
                        Grid.Column="1"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=month}"/>

                            <TextBox Name="month_tb" MaxWidth="80"
                                     MaxLength="2"
                                     TextAlignment="Center"
                                      FontSize="18"
                                     PreviewTextInput="month_tb_PreviewTextInput"
                                      MinWidth="80" Grid.Row="1">
                            </TextBox>
                        </Grid>
                    </Border>

                    <Border Margin="5 5 5 10" 
                        Grid.Column="3"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource greenDarkLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=current_balance}"/>

                            <TextBox Name="current_balance_tb" MaxWidth="300"
                                     IsEnabled="False"
                                      FontSize="18"
                                      MinWidth="150" Grid.Row="1">
                            </TextBox>
                        </Grid>
                    </Border>

                </Grid>
            </Border>


            <ListView x:Name="safelistview" Grid.Row="2" 
                      ItemsSource="{Binding}"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                <ListView.View>
                    <GridView>
                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Border Margin="5 5 5 10"   
                                        HorizontalAlignment="Center"
                                        CornerRadius="20 20 20 0"
                                        Background="{DynamicResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Content="{lex:Loc Key=description}"/>

                                        <TextBox Name="search_desc_tb" MaxWidth="400"
                                                 TextChanged="Year_tb_OnTextChanged"
                                                 FontSize="18"
                                                 MinWidth="150" Grid.Row="1">
                                        </TextBox>
                                    </Grid>
                                </Border>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=discrption}" 
                                           Foreground="{DynamicResource textColor}"
                                           MinWidth="100" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Label Content="{lex:Loc Key=amount}" Grid.Column="1"
                                           MinWidth="100" FontSize="20" Foreground="{DynamicResource textColor}"
                                            FontWeight="Bold"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label  Grid.Column="1" MinWidth="100" 
                                            Foreground="{DynamicResource textColor}"
                                            Content="{Binding Path=cash_in}"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Border Margin="5 5 5 10"   
                                            Grid.Column="2"
                                        HorizontalAlignment="Center"
                                        CornerRadius="20 20 20 0"
                                        Background="{DynamicResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Content="{lex:Loc Key=name}"/>

                                        <TextBox Name="search_name_tb" MaxWidth="400"
                                                 TextChanged="Year_tb_OnTextChanged"
                                              FontSize="18"
                                              MinWidth="150" Grid.Row="1">
                                        </TextBox>
                                    </Grid>
                                </Border>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label  Grid.Column="2" MinWidth="120" 
                                            Foreground="{DynamicResource textColor}"
                                            Content="{Binding Path=person}"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Border Margin="5 5 5 10"   
                                            Grid.Column="3"
                                        HorizontalAlignment="Center"
                                        CornerRadius="20 20 20 0"
                                        Background="{DynamicResource orangeLightLinear}">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Content="{lex:Loc Key=day}"/>

                                        <TextBox Name="search_date_tb" MaxWidth="100"
                                                 MaxLength="2"
                                                 PreviewTextInput="month_tb_PreviewTextInput"
                                                 TextChanged="Year_tb_OnTextChanged"
                                                 FontSize="18"
                                                 MinWidth="80" Grid.Row="1">
                                        </TextBox>
                                    </Grid>
                                </Border>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Grid.Column="3" MinWidth="120" 
                                           Foreground="{DynamicResource textColor}"
                                           Content="{Binding Path=p_date}" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>

                
            </ListView>


            <Border Grid.Row="3" Height="100" 
                     CornerRadius="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Content="{lex:Loc Key=settlement}" 
                           Foreground="{DynamicResource textColor}"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="10 0"/>

                    <Border Margin="5 5 5 10" 
                            Grid.Column="1"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=current_balance}"/>

                            <TextBox Name="current_balance_enter_tb" MaxWidth="300"
                                     PreviewTextInput="current_balance_enter_tb_PreviewTextInput"
                                     Grid.Row="1">
                            </TextBox>
                        </Grid>
                    </Border>

                    <Border Margin="5 5 5 10"   
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=date}"/>

                            <DatePicker Name="sattling_date" MaxWidth="300"
                                        Text="Add Date"
                                      FontSize="18"
                                      MinWidth="200" Grid.Row="1">
                            </DatePicker>
                        </Grid>
                    </Border>

                    <Button Style="{StaticResource dangerBtn}" 
                            Click="settling_click_btn"
                            Margin="10 0 0 0"
                            Width="100"
                            Height="50"
                            Content="{lex:Loc Key=settlement}"
                            Grid.Column="3"/>

                </Grid>
            </Border>

        </Grid>
    </Border>
</UserControl>
