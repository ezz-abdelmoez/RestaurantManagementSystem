<UserControl x:Class="SalesManagement.files.controllers.ExpensesController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d" >
    <Border Background="{DynamicResource pageBackground}"
            CornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Border Background="{StaticResource greenDarkLinear}"
                    CornerRadius="20 20 0 0">

                <Grid>
                    <Label HorizontalAlignment="Center"
                           Content="{lex:Loc Key=expenses}" Style="{StaticResource pageTitle}"/>

                    <Border Style="{StaticResource imag_border}"
                            HorizontalAlignment="Right"
                            Margin="5"
                            Height="50">
                        <Image Source="/assets/img/refresh-button.png"
                               MouseDown="refresh_page_md"></Image>
                    </Border>

                </Grid>

            </Border>

            <Border Margin="5 5 5 10" Grid.Row="1"  
                            HorizontalAlignment="Center"
                            CornerRadius="20 0 20 0"
                            Style="{StaticResource border_shadow}">

                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lex:Loc Key=add_expenses}"
                           Foreground="{DynamicResource textColor}"
                           FontWeight="Bold" FontSize="20"
                           Margin="5"/>

                    <WrapPanel Grid.Column="1">

                        <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=date}"/>

                                <DatePicker Name="spend_date" MaxWidth="150" MinWidth="150"
                                            Text="Add Date"
                                         Grid.Row="1"/>

                            </Grid>

                        </Border>

                        <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                                Grid.Column="1"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=description}"/>

                                <TextBox x:Name="spend_des_tb"
                                         TextAlignment="Center"
                                         MinWidth="200" Grid.Row="1"/>

                            </Grid>

                        </Border>

                        <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                                Grid.Column="2"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=value}"/>

                                <TextBox x:Name="spend_value_tb" MinWidth="100" Width="100" 
                                         PreviewTextInput="spend_value_tb_PreviewTextInput"
                                         Grid.Row="1"
                                         TextAlignment="Center"/>

                            </Grid>

                        </Border>

                        <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                                Grid.Column="3"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=notes}"/>

                                <TextBox x:Name="notes_tb" MinWidth="300" Grid.Row="1"
                                         TextAlignment="Center"/>

                            </Grid>

                        </Border>

                        <Border Grid.Column="5" MinWidth="100" MinHeight="50"
                                Margin="20 0 0 0"
                                Width="100" Height="100"
                                Style="{StaticResource imag_border}"
                                >
                            <Image MouseDown="add_new_spend_img_md" Source="save.png"/>
                        </Border>
                    </WrapPanel>

                </Grid>

            </Border>

            <Border Margin="5 5 5 0" Grid.Row="2"  
                            HorizontalAlignment="Stretch"
                            CornerRadius="20 0 20 0"
                            Style="{StaticResource border_shadow}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lex:Loc Key=search}"
                           FontWeight="Bold" FontSize="20"
                           Foreground="{DynamicResource textColor}"
                           Margin="5"/>
                    <TextBox x:Name="search_tb" Grid.Column="1"  VerticalAlignment="Center"
                             TextChanged="day_tb_TextChanged"
                             MinWidth="200" MaxWidth="300"/>

                    <Border Margin="5 5 5 10"  
                            Grid.Column="3"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=day}"/>

                            <TextBox x:Name="day_tb" Width="60" MinWidth="60"
                                     MaxLength="2"
                                     PreviewTextInput="day_tb_PreviewTextInput"
                                         TextAlignment="Center"
                                         Grid.Row="1"/>

                        </Grid>

                    </Border>

                    <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                                Grid.Column="4"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=month}"/>

                            <TextBox  x:Name="month_tb"
                                     Width="60" MinWidth="60"
                                     MaxLength="2"
                                     PreviewTextInput="day_tb_PreviewTextInput"
                                         TextAlignment="Center"
                                          Grid.Row="1" />

                        </Grid>

                    </Border>

                    <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                                Grid.Column="5"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=year}"/>

                            <TextBox x:Name="year_tb" Grid.Row="1"
                                     Width="80" MinWidth="60"
                                     MaxLength="4"
                                     PreviewTextInput="day_tb_PreviewTextInput"
                                     TextAlignment="Center"/>

                        </Grid>

                    </Border>

                </Grid>

            </Border>

            <ListView x:Name="spendListview" Grid.Row="3"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                <ListView.View>
                    <GridView>

                        <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                        DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                        <GridViewColumn Header="{lex:Loc Key=amount}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=cash}" 
                                             KeyDown="value_key_down"
                                               MinWidth="100" FontSize="18"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=description}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=discrption}" 
                                             KeyDown="desc_key_down"
                                               Foreground="{StaticResource textColor}"
                                               Width="200" 
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=notes}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=notes}" 
                                             KeyDown="notes_key_down"
                                               Foreground="{StaticResource textColor}"
                                             Width="200"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=spend_date}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <DatePicker 
                                                SelectedDate="{Binding Path=spend_date}"
                                        SelectedDateChanged="date_changes"
                                               Foreground="{StaticResource textColor}"
                                                MinHeight="50"
                                               MinWidth="250"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=delete}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource imag_border}">
                                        <Image MouseDown="delete_spend_image_md" Width="40" Height="40" Source="delete.png"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>

            </ListView>

            <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Left"
                    Grid.Row="4"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lex:Loc Key=total}"/>

                    <TextBox x:Name="tot_spend_tb" Height="40" 
                                     IsEnabled="False"
                                     MinWidth="200" Grid.Column="1"/>

                </Grid>

            </Border>
        </Grid>
    </Border>
</UserControl>
