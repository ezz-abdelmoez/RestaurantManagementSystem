<UserControl x:Class="SalesManagement.files.controllers.AddEmpController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             mc:Ignorable="d" >
    <Border Background="#B2D9D9D9"
            CornerRadius="20" Padding="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Grid HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Border CornerRadius="20 0 20 0" Grid.Column="0"
                                    Margin="0 5 0 0"
                                    Padding="10"
                                Background="{StaticResource greenDarkLinear}">
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Job" FontSize="20"
                                       Margin="0 0 50 0"/>

                        <CheckBox Grid.Column="1"
                                          VerticalContentAlignment="Center"
                                          MinHeight="50"
                              Margin="0 0 20 0">
                        </CheckBox>

                        <TextBox MinWidth="200" MinHeight="50" Grid.Column="2" Visibility="Collapsed"/>
                        <ComboBox Width="200" Grid.Column="2" />
                    </Grid>
                </Border>

                <Border CornerRadius="20 0 20 0" Grid.Column="1" 
                                    Margin="0 5 0 0"
                                    Padding="10"
                                Background="{StaticResource greenDarkLinear}">
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Name" FontSize="20"
                                       Margin="0 0 50 0"/>

                        <TextBox MinWidth="200" MinHeight="50" Grid.Column="2"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Margin="5 5 5 10" Grid.Row="2"
                    MinHeight="60"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource greenDarkLinear}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Stretch"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeDeepRadial}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="Address"/>

                            <TextBox MaxWidth="600" MinWidth="600" Grid.Row="1"/>

                        </Grid>

                    </Border>
                    
                </Grid>
            </Border>

            <Border Margin="5 5 5 10" Grid.Row="3"
                    MinHeight="60"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource greenDarkLinear}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeDeepRadial}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="Salary"/>

                            <TextBox Width="200" Grid.Row="1"/>

                        </Grid>

                    </Border>
                    <Border Margin="5 5 5 10"   
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeDeepRadial}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="Work Hours"/>

                            <TextBox Width="200" Grid.Row="1"/>

                        </Grid>

                    </Border>
                    <Border Margin="5 5 5 10"   
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeDeepRadial}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="Phone"/>

                            <TextBox Width="200" Grid.Row="1"/>

                        </Grid>

                    </Border>
                </Grid>
            </Border>

            <Border Margin="5 5 5 10" Grid.Row="4"
                    MinHeight="60"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource greenDarkLinear}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeDeepRadial}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="Date of Hiring"/>

                            <TextBox Width="200" Grid.Row="1"/>

                        </Grid>

                    </Border>
                    <Border Margin="5 5 5 10"   
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{StaticResource orangeDeepRadial}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="Holidays Balance"/>

                            <TextBox Width="200" Grid.Row="1"/>

                        </Grid>

                    </Border>
                </Grid>
            </Border>

            <Button Style="{StaticResource calcBtn}" Grid.Row="5"
                    Width="200" Height="60" Content="Save"/>

        </Grid>
    </Border>
</UserControl>
