<UserControl x:Class="SalesManagement.files.controllers.CashierAccounts"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d">
    
    <Border Background="{DynamicResource pageBackground}"
            CornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Border Margin="5"   
                            Grid.Row="0"
                            HorizontalAlignment="Stretch"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource pageBackground}">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="10" BlurRadius="20" Color="{DynamicResource shadow1}"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lex:Loc Key=search}"
                           Foreground="{DynamicResource textColor}"
                           FontWeight="Bold" FontSize="20"
                           Margin="5"/>

                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Margin="5 0 5 0"   
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=day}"/>

                                <TextBox x:Name="day_tb" MinWidth="60" Width="60"
                                         MaxLength="2"
                                         PreviewTextInput="day_tb_PreviewTextInput"
                                         TextAlignment="Center"
                                         TextChanged="day_tb_TextChanged"
                                         Grid.Row="1"/>

                            </Grid>

                        </Border>

                        <Border Margin="5 0"   
                            HorizontalAlignment="Center"
                                Grid.Column="1"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=month}"/>

                                <TextBox x:Name="month_tb" 
                                         MinWidth="60" Width="60"
                                         MaxLength="2"
                                         PreviewTextInput="day_tb_PreviewTextInput"
                                         TextAlignment="Center"
                                         TextChanged="day_tb_TextChanged"
                                         Text="11"
                                          Grid.Row="1"/>

                            </Grid>

                        </Border>

                        <Border Margin="5 0"   
                            HorizontalAlignment="Center"
                                Grid.Column="2"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=cashier_remains}"/>

                                <TextBox x:Name="year_tb" 
                                         MinWidth="60" Width="80"
                                         MaxLength="4"
                                         PreviewTextInput="day_tb_PreviewTextInput"
                                         Grid.Row="1"
                                         TextAlignment="Center"
                                         TextChanged="day_tb_TextChanged"
                                         Text="2022"/>

                            </Grid>

                        </Border>

                        <Border Margin="5 0"   
                            HorizontalAlignment="Center"
                                Grid.Column="4"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Label Content="{lex:Loc Key=user}"/>

                                <ComboBox Name="user_combo"  Grid.Row="1"
                                          IsEditable="True"
                                          SelectionChanged="user_combo_SelectionChanged"
                                          >
                                </ComboBox>

                            </Grid>

                        </Border>

                    </Grid>

                    <Border Style="{StaticResource imag_border}"
                            HorizontalAlignment="Right" Grid.Column="2"
                            Margin="5"
                            Height="50">
                        <Image Source="/assets/img/refresh-button.png"
                               MouseDown="refresh_page_md"></Image>
                    </Border>

                </Grid>

            </Border>

            <ListView x:Name="accListview"  Background="{DynamicResource subBackground}"
                      Grid.Row="1"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                <ListView.View>
                    <GridView>

                        <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                        DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                        <GridViewColumn Header="{lex:Loc Key=name}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=user_name}" 
                                               Foreground="{DynamicResource textColor}"
                                               MinWidth="150" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=value}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=cash}" 
                                               Foreground="{DynamicResource textColor}"
                                               MinWidth="150" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=description}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label 
                                               Foreground="{DynamicResource textColor}"
                                               Width="300">
                                        <Label.Content>
                                            <AccessText TextWrapping="Wrap" Text="{Binding Path=det}"/>
                                        </Label.Content>
                                    </Label>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=date}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=safe_date}" 
                                               Foreground="{DynamicResource textColor}"
                                               MinWidth="150" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=money_deficit}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=lack}"
                                               Foreground="{DynamicResource textColor}"
                                               MinWidth="150" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>

            </ListView>

            <Border Grid.Row="2" 
                    CornerRadius="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Left"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="{lex:Loc Key=supply}"/>

                            <TextBox x:Name="supply_tb" MinHeight="40" 
                                     IsEnabled="False"
                                     MinWidth="200" Grid.Column="1"/>

                        </Grid>

                    </Border>

                    <Border Margin="5 5 5 10"   
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="{lex:Loc Key=money_deficit}"/>

                            <TextBox x:Name="lack_tb" MinHeight="40" 
                                     IsEnabled="False"
                                     MinWidth="200" Grid.Column="1"/>

                        </Grid>

                    </Border>

                </Grid>
            </Border>

        </Grid>
    </Border>
</UserControl>
