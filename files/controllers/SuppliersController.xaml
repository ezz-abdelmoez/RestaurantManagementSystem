<UserControl x:Class="SalesManagement.files.controllers.SuppliersController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d" >
    <Border CornerRadius="20" Background="{DynamicResource pageBackground}"
            HorizontalAlignment="Center" >
        <Grid 
               >
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Border CornerRadius="20 20 0 0"
                    Background="{StaticResource greenDarkLinear}">
                <Grid>
                    
                    <Label Content="{lex:Loc Key=sups}" Style="{StaticResource pageTitle}"
                           HorizontalAlignment="Center"/>

                    
                    <Border Style="{StaticResource imag_border}"
                            HorizontalAlignment="Right"
                            Margin="5"
                            Height="50">
                        <Image Source="/assets/img/refresh-button.png"
                               MouseDown="refresh_page_md"></Image>
                    </Border>
                </Grid>


            </Border>

            <Border  Margin="5"   
                     Padding="5"
                        HorizontalAlignment="Center"
                        Grid.Row="1"
                        CornerRadius="20"
                        Background="{DynamicResource pageBackground}">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="5" BlurRadius="20" Color="{DynamicResource shadow1}"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lex:Loc Key=sup}" Foreground="{DynamicResource textColor}" FontSize="20"/>

                    <ComboBox Name="vender_combo"
                              IsEditable="True"  Grid.Column="1"
                              SelectionChanged="Vender_combo_OnSelectionChanged"
                                      Margin="0 0 10 0">
                    </ComboBox>

                    <TextBox Name="vandor_amount_tb" Grid.Column="2" Width="150"
                             Height="50"
                             IsEnabled="False"
                                     />

                    <Button Style="{StaticResource dangerBtn}"
                            Click="show_new_sup_btn_click"
                                    Margin="30 0 50 0"
                                    Grid.Column="3"
                                    Content="{lex:Loc Key=new}" Width="60" Height="50"/>

                    <Grid Grid.Column="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <Border  
                                    Padding="5"
                                    Grid.Column="0"
                                    HorizontalAlignment="Center"
                                    CornerRadius="20 20 20 0"
                                    Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Label Content="{lex:Loc Key=day}"/>
                                <TextBox Width="60" Name="day_tb"
                                         MaxLength="2"
                                         PreviewTextInput="day_tb_PreviewTextInput"
                                                    Grid.Row="1"
                                                 TextChanged="Day_tb_OnTextChanged"
                                                      FontSize="18"
                                                      MinWidth="60">
                                </TextBox>
                            </Grid>
                        </Border>

                        <Border  Margin="10 0"
                                    Padding="5"
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    CornerRadius="20 20 20 0"
                                    Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Label Content="{lex:Loc Key=month}"/>
                                <TextBox Width="60" Name="month_tb"
                                         MaxLength="2"
                                         PreviewTextInput="day_tb_PreviewTextInput"
                                                    Grid.Row="1"
                                                 TextChanged="Day_tb_OnTextChanged"
                                                      FontSize="18"
                                                      MinWidth="60">
                                </TextBox>
                            </Grid>
                        </Border>

                        <Border  
                                    Padding="5"
                                    Grid.Column="2"
                                    HorizontalAlignment="Center"
                                    CornerRadius="20 20 20 0"
                                    Background="{DynamicResource orangeLightLinear}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Label Content="{lex:Loc Key=year}"/>
                                <TextBox Width="100" Name="year_tb"
                                         MaxLength="4"
                                                    Grid.Row="1"
                                         PreviewTextInput="day_tb_PreviewTextInput"
                                                 TextChanged="Day_tb_OnTextChanged"
                                                      FontSize="18"
                                                      MinWidth="60">
                                </TextBox>
                            </Grid>
                        </Border>

                    </Grid>

                </Grid>

            </Border>

            <TabControl Grid.Row="2" Background="Transparent">
                <TabItem>
                    <TabItem.Header>
                        <Border MinWidth="100" MinHeight="50" 
                                CornerRadius="20"
                                Padding="5"
                                 Style="{StaticResource blueLightRadialBorder}">
                            <Label Content="{lex:Loc Key=the_accounts}" FontSize="20"/>
                        </Border>
                    </TabItem.Header>
                    <Grid>
                        <ListView x:Name="accountsListview"  Background="{DynamicResource subBackground}"
                                  ItemsSource="{Binding}"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                            <ListView.View>
                                <GridView>

                                    <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                                    DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                                    <GridViewColumn Header="{lex:Loc Key=the_amount}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Path=buy_value}" 
                                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{lex:Loc Key=type}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Path=pay_or_add}" 
                                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{lex:Loc Key=date}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Path=buy_date}" 
                                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{lex:Loc Key=remaining}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Path=remain}" 
                                                       Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="{lex:Loc Key=delete}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border HorizontalAlignment="Center" Grid.Column="5" Style="{StaticResource imag_border}"
                                                        Width="100" Height="40" >
                                                    <Image Source="delete.png" MouseDown="delete_account_image_md"/>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>

                        </ListView>
                    </Grid>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <Border MinWidth="100" MinHeight="50" 
                                CornerRadius="20"
                                Padding="5"
                                 Style="{StaticResource blueLightRadialBorder}">
                            <Label Content="{lex:Loc Key=purchase_invoices}" FontSize="20"/>
                        </Border>
                    </TabItem.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Margin="5 5 5 10" 
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=bill_num}"/>

                                    <ComboBox Name="bill_combo" MaxWidth="300"
                                              ItemsSource="{Binding}"
                                              SelectedValuePath="{Binding bill_no}"
                                              DisplayMemberPath="{Binding bill_no}"
                                              SelectionChanged="Bill_combo_OnSelectionChanged"
                                          MinHeight="50"
                                      FontSize="18"
                                      MinWidth="150" Grid.Row="1">
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <Border Margin="5 5 5 10" 
                                    Grid.Column="1"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=bill_date}"/>

                                    <DatePicker Name="bill_date" MaxWidth="300"
                                                IsEnabled="False"
                                          MinHeight="50"
                                                Text="Enter Date"
                                      FontSize="18"
                                      MinWidth="150" Grid.Row="1">
                                    </DatePicker>
                                </Grid>
                            </Border>
                            
                        </Grid>


                        <ScrollViewer Grid.Row="1">
                            <ListView x:Name="billsListview"  Background="{DynamicResource subBackground}"
                                      ItemsSource="{Binding}"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                                        DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                                        <GridViewColumn Header="{lex:Loc Key=cate1}">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Label 
                                                           Foreground="{DynamicResource textColor}"
                                                            Width="300" >
                                                        <Label.Content>
                                                            <AccessText TextWrapping="Wrap" Text="{Binding Path=item_name}"/>
                                                        </Label.Content>
                                                    </Label>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="{lex:Loc Key=price}">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Label Content="{Binding Path=buy_price}" 
                                                           Foreground="{DynamicResource textColor}"
                                               MinWidth="150" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="{lex:Loc Key=qty}">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Label Content="{Binding Path=act_qty}" 
                                                           Foreground="{DynamicResource textColor}"
                                               MinWidth="150" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="{lex:Loc Key=total}">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Label Content="{Binding Path=tot}" 
                                                           Foreground="{DynamicResource textColor}"
                                                       MinWidth="150"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                                
                            </ListView>
                        </ScrollViewer>

                    </Grid>
                </TabItem>
            </TabControl>

            <Border Grid.Row="3" Height="100">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Margin="5 5 5 10" 
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=payment}"/>

                            <TextBox Name="pay_tb" MaxWidth="300"
                                     PreviewTextInput="pay_tb_PreviewTextInput"
                                      FontSize="18"
                                      MinWidth="150" Grid.Row="1">
                            </TextBox>
                        </Grid>
                    </Border>

                    <Border Margin="5 5 5 10" 
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=payment_date}"/>

                            <DatePicker Name="pay_date"
                                        Text="Enter Date"
                                MinWidth="200" MaxHeight="300"
                                      FontSize="18" Grid.Row="1">
                            </DatePicker>
                        </Grid>
                    </Border>

                    <Button Click="pay_btn_click" Content="{lex:Loc Key=pay}"
                            Style="{DynamicResource dangerBtn}"
                            Grid.Column="2" Width="100" Height="50"/>
                </Grid>
            </Border>
            
            
            <Border Background="#B2D9D9D9" Visibility="Collapsed" Grid.RowSpan="6" Name="border_new_sub"
                CornerRadius="20" Padding="5">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" 
                      >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <Border Margin="5 5 5 10" 
                            MinHeight="60"
                            Width="400"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource pageBackground}">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource shadow1}" ShadowDepth="10" BlurRadius="20"/>
                        </Border.Effect>

                        <WrapPanel HorizontalAlignment="Center">
                            <Border Margin="5 5 5 10"   
                                    HorizontalAlignment="Center"
                                    CornerRadius="20 20 20 0"
                                    Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=sub_name}"/>

                                    <TextBox Name="new_sup_name_tb" Width="350" Grid.Row="1"/>

                                </Grid>

                            </Border>
                            <Border Margin="5 5 5 10"   
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    CornerRadius="20 20 20 0"
                                    Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=address}"/>

                                    <TextBox Name="new_address_tb" Width="350" Grid.Row="1"/>

                                </Grid>

                            </Border>
                            <Border Margin="5 5 5 10"   
                                    Grid.Column="2"
                                    HorizontalAlignment="Center"
                                    CornerRadius="20 20 20 0"
                                    Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=tel}"/>

                                    <TextBox Name="new_phone_tb" Width="350" Grid.Row="1"/>

                                </Grid>

                            </Border>
                            <Border Margin="5 5 5 10"   
                                    Grid.Column="3"
                                    HorizontalAlignment="Center"
                                    CornerRadius="20 20 20 0"
                                    Background="{DynamicResource orangeLightLinear}">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <Label Content="{lex:Loc Key=email}"/>

                                    <TextBox Name="new_email_tb" Width="350" Grid.Row="1"/>

                                </Grid>

                            </Border>

                            
                        </WrapPanel>
                    </Border>

                    <Button Style="{StaticResource dangerBtn}" Grid.Row="1"
                            Click="save_new_sup_btn_click"
                            Width="150" Height="60" Content="{lex:Loc Key=save}"/>

                    <Button Style="{StaticResource dangerBtn1}" Grid.Row="1"
                            Click="hide_border_new_sup"
                            HorizontalAlignment="Left"
                            Width="100" Height="60" Content="{lex:Loc Key=cancel}"/>


                </Grid>
            </Border>
            
        </Grid>
    </Border>
</UserControl>
