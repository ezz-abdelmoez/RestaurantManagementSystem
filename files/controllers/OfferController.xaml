<UserControl x:Class="SalesManagement.files.controllers.OfferController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d" >

    <Border 
            CornerRadius="20" >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="{DynamicResource pageBackground}"
                    CornerRadius="20" Margin="5 10">
                <Border.Effect>
                    <DropShadowEffect Color="#FF003CDA"/>
                </Border.Effect>
                <WrapPanel>

                    <Border Margin="5 5 5 10" 
                                Grid.Row="1"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Label Content="{lex:Loc Key=cate1}"/>

                            <ComboBox  x:Name="offer_cate_combo"
                                      SelectionChanged="offer_cate_combo_SelectionChanged"
                                      IsEditable="True" Grid.Row="1">
                            </ComboBox>




                        </Grid>
                    </Border>

                    <Border  
                                    Padding="5"
                                Margin="5"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=item}"/>

                            <ComboBox  Grid.Row="1" x:Name="offer_item_combo"
                                       SelectionChanged="offer_item_combo_SelectionChanged"
                                       IsEditable="True">
                            </ComboBox>

                        </Grid>
                    </Border>

                    <Border  
                                    Padding="5"
                                    Margin="5"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=price}"/>

                            <TextBox  Grid.Row="1" x:Name="price_tb"
                                              MinWidth="100"
                                      PreviewTextInput="offer_tb_PreviewTextInput"
                                  IsEnabled="False"
                                      Height="40"
                                      FontSize="18">
                            </TextBox>

                        </Grid>
                    </Border>

                    <Border  
                                    Padding="5"
                                Margin="5"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=offer}"/>

                            <TextBox  Grid.Row="1" x:Name="offer_tb"
                                      PreviewTextInput="offer_tb_PreviewTextInput"
                                              MinWidth="100"
                                      MaxWidth="100"
                                      Height="40"
                                      FontSize="18">
                            </TextBox>

                        </Grid>
                    </Border>

                    <Border  
                                    Padding="5"
                                Margin="5"
                                HorizontalAlignment="Center"
                                CornerRadius="20 20 20 0"
                                Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=end_date}"/>

                            <DatePicker  Grid.Row="1" x:Name="end_date_datePicker"
                                     Text="Add Date"
                                     MinWidth="150"
                                      Height="40"
                                      FontSize="18">
                            </DatePicker>

                        </Grid>
                    </Border>

                    <Border Style="{StaticResource imag_border}"
                                Margin="10"
                                >
                        <Image MouseDown="save_offer_img_mouse_down" Width="80" Height="80" Source="save.png"/>

                    </Border>

                </WrapPanel>
            </Border>

            <ListView x:Name="offerListview" Grid.Row="1"  Background="{DynamicResource subBackground}"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                <ListView.View>
                    <GridView>

                        <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                        DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                        <GridViewColumn Header="{lex:Loc Key=cate1}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Width="200"
                                               Foreground="Black"
                                              >
                                        <Label.Content>
                                            <AccessText TextWrapping="Wrap" Text="{Binding Path=food}"/>
                                        </Label.Content>
                                    </Label>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=offer}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=new_price}" 
                                               Foreground="Black"
                                               MinWidth="100" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=previous}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=old_price}" 
                                               Foreground="Black"
                                               MinWidth="100" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=end_date}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=end_time}" 
                                               Foreground="Black"
                                               MinWidth="150" Padding="5" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=delete}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource imag_border}" MinWidth="100"
                                            Grid.Column="8">
                                        <Image Source="delete.png"
                                               MouseDown="delete_offer_mouse_down"
                                               Width="40" Height="40"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>

               

            </ListView>
        </Grid>
    </Border>
</UserControl>
