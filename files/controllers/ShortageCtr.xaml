<UserControl x:Class="SalesManagement.files.controllers.ShortageCtr"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
             lex:LocalizeDictionary.DesignCulture="en-US"
             lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
             lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d" 
            >
    <Grid  >

        <ListView x:Name="shortsListView" Grid.Column="0" Background="Gray"
                          HorizontalContentAlignment="Center" 
                       HorizontalAlignment="Left" 
                      ItemsSource="{Binding}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn>
                                <GridViewColumn.Header>
                                    <Button Content="{lex:Loc Key=item}" 
                                                            MinWidth="150" 
                                                            Style="{StaticResource calcBtn1}"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label 
                                            Width="400" >
                                            <Label.Content>
                                                <AccessText TextWrapping="Wrap" Text="{Binding Path=food}"/>
                                            </Label.Content>
                                        </Label>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn>
                                <GridViewColumn.Header>
                                    <Button Content="{lex:Loc Key=qty}" 
                                                            MinWidth="100" 
                                                            Style="{StaticResource calcBtn1}"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Label Content="{Binding Path=SumOfnofood}" 
                                                           MinWidth="150"  FontSize="20"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            
    </Grid>
</UserControl>
