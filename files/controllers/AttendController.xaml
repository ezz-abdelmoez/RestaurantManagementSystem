<UserControl x:Class="SalesManagement.files.controllers.AttendController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d">
    <Border Background="{StaticResource pageBackground}"
            CornerRadius="0 0 20 20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>


                <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                                Grid.Column="0"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Label Content="{lex:Loc Key=month}" />

                        <TextBox  Name="month_tb"
                                         TextAlignment="Center"
                                         Text="11"
                                  PreviewTextInput="month_tb_PreviewTextInput"
                                         MinWidth="60"
                                  Width="60"
                                  MaxLength="2"
                                  Grid.Row="1"/>

                    </Grid>

                </Border>

                <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                                Grid.Column="1"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Label Content="{lex:Loc Key=year}"/>

                        <TextBox x:Name="year_tb" 
                                 PreviewTextInput="month_tb_PreviewTextInput"
                                         MinWidth="60"
                                  Width="80"
                                  MaxLength="4"
                                 Grid.Row="1"
                                         TextAlignment="Center"
                                         Text="2022"/>

                    </Grid>

                </Border>

                <Button Visibility="Visible" Click="show_details_btn" Content="{lex:Loc Key=view}" Grid.Column="2" 
                        Width="100" Height="50" Style="{StaticResource dangerBtn}"/>

                <Grid Grid.Column="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="director_visa_btn" Style="{StaticResource dangerBtn}" Content="{lex:Loc Key=director_visa}" Width="200" Height="60" Click="director_visa_btn_Click"/>
                    <Border x:Name="approve_border" Width="50" Height="50" Style="{StaticResource imag_border}" Grid.Column="1"
                            Margin="10 0 10 0">
                        <Image Source="ok.ico"/>
                    </Border>
                    <Border x:Name="not_approve_border" Width="50" Height="50" 
                            Style="{StaticResource imag_border}" Grid.Column="2">
                        <Image Source="delete.png"/>
                    </Border>
                </Grid>

            </Grid>

            <ListView x:Name="attendListview" 
                      Grid.Row="1"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                <ListView.View>
                    <GridView>
                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="{lex:Loc Key=name}" 
                                            MinWidth="100" 
                                            Style="{StaticResource calcBtn1}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=emp}" 
                                               Foreground="{DynamicResource textColor}"
                                               MinWidth="100" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="{lex:Loc Key=basic}" 
                                            MinWidth="100" 
                                            Style="{StaticResource calcBtn1}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=salary}" 
                                               Foreground="{DynamicResource textColor}"
                                               MinWidth="100" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="{lex:Loc Key=attend}" 
                                            MinWidth="100" 
                                            Style="{StaticResource calcBtn1}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=attend}" 
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                             KeyDown="attend_change_tb"
                                               MinWidth="100"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="{lex:Loc Key=holidays}" 
                                            MinWidth="100" 
                                            Style="{StaticResource calcBtn1}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=vac}" 
                                             KeyDown="holiday_change_tb"
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                               MinWidth="100" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="{lex:Loc Key=absence}" 
                                            MinWidth="100" 
                                            Style="{StaticResource calcBtn1}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=absence}"
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                             KeyDown="absence_change_tb"
                                               MinWidth="100"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="{lex:Loc Key=delay}" 
                                            MinWidth="100" 
                                            Style="{StaticResource calcBtn1}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=late}"
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                             KeyDown="late_change_tb"
                                               MinWidth="100"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="{lex:Loc Key=penalty}" 
                                            MinWidth="100" 
                                            Style="{StaticResource calcBtn1}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=penality}"
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                             KeyDown="penality_change_tb"
                                               MinWidth="100" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="{lex:Loc Key=over_time}" 
                                            MinWidth="100" 
                                            Style="{StaticResource calcBtn1}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=offer_time}"
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                             KeyDown="offer_time_change_tb"
                                               MinWidth="100" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="{lex:Loc Key=reward}" 
                                            MinWidth="100" 
                                            Style="{StaticResource calcBtn1}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Path=reward}"
                                             PreviewTextInput="TextBox_PreviewTextInput"
                                             KeyDown="reward_change_tb"
                                               MinWidth="100" FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <Button Content="{lex:Loc Key=salary}" 
                                            MinWidth="100" 
                                            Style="{StaticResource calcBtn1}"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=net_salary}"
                                               Foreground="{DynamicResource textColor}"
                                               MinWidth="100"  FontSize="20"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>

            </ListView>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>


                <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                                Grid.Column="0"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="{lex:Loc Key=total}" />

                        <TextBox MaxWidth="150" Name="total"
                                 IsEnabled="False"
                                         TextAlignment="Center"
                                         MinWidth="150" Grid.Column="1"/>

                    </Grid>

                </Border>


                <Button Click="director_visa_btn_Click" Style="{StaticResource dangerBtn}" Content="{lex:Loc Key=paycheck_printing}" Grid.Column="2" Width="300"
                        Height="50"/>

            </Grid>

        </Grid>
    </Border>
</UserControl>
