<UserControl x:Class="SalesManagement.files.controllers.PurchaseController"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagement.files.controllers"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="en-US"
        lex:ResxLocalizationProvider.DefaultAssembly="SalesManagement"
        lex:ResxLocalizationProvider.DefaultDictionary="Langs"
             mc:Ignorable="d" >
    <Border CornerRadius="20" Background="{DynamicResource pageBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Border 
                    CornerRadius="20 20 0 0"
                    Background="{StaticResource greenDarkLinear}">

                <Grid>
                    <Label Content="{lex:Loc Key=purchases}" 
                           Style="{DynamicResource pageTitle}"/>
                    
                    <Border Style="{StaticResource imag_border}"
                            HorizontalAlignment="Right"
                            Margin="5"
                            Height="50">
                        <Image Source="/assets/img/refresh-button.png"
                               MouseDown="refresh_page_md"></Image>
                    </Border>
                </Grid>
            </Border>
            
            <Border Height="50" Margin="5 5 5 10"   
                        HorizontalAlignment="Center"
                    Grid.Row="1"
                        CornerRadius="20 0 20 0"
                        Background="{DynamicResource orangeLightLinear}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{lex:Loc Key=sup}" FontSize="20"/>

                    <ComboBox Name="vendor_combo" Grid.Column="1"
                              SelectionChanged="Vendor_combo_OnSelectionChanged"
                              IsEditable="True"
                                      Margin="0 0 10 0">
                    </ComboBox>

                    <TextBox Name="vendor_value_tb" Grid.Column="2" MaxWidth="300"
                                     IsEnabled="False"
                                     MinWidth="100"/>

                </Grid>

            </Border>

            <Border Background="{DynamicResource pageBackground}"
                    Padding="10"
                    HorizontalAlignment="Center"
                    CornerRadius="20"
                    Margin="10"
                            Grid.Row="2"
                            >
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="5" BlurRadius="20" Color="{DynamicResource shadow1}"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=cate1}"/>

                            <ComboBox Name="store_item_combo"
                                      SelectionChanged="Store_item_combo_OnSelectionChanged"
                                      IsEditable="True" Grid.Row="1">
                            </ComboBox>
                        </Grid>
                    </Border>
                    <Border Margin="5 5 5 10"   
                        Grid.Column="1"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=purchase_price}"/>

                            <TextBox Name="buy_price_tb" MaxWidth="400"
                                     IsEnabled="False"
                                      FontSize="18"
                                      MinWidth="200" Grid.Row="1">
                            </TextBox>
                        </Grid>
                    </Border>
                    <Border Margin="5 5 5 10"   
                        Grid.Column="2"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=qty}"/>

                            <TextBox Name="qty_tb" MaxWidth="400"
                                     TextChanged="Qty_tb_OnTextChanged"
                                     PreviewTextInput="qty_tb_PreviewTextInput"
                                      FontSize="18"
                                      MinWidth="200" Grid.Row="1">
                            </TextBox>
                        </Grid>
                    </Border>
                    <Border Margin="5 5 5 10"   
                        Grid.Column="3"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=total}"/>

                            <TextBox Name="total_tb" MaxWidth="400"
                                     IsEnabled="False"
                                      FontSize="18"
                                      MinWidth="200" Grid.Row="1">
                            </TextBox>
                        </Grid>
                    </Border>

                    <Button Content="{lex:Loc Key=add}" MinWidth="100" Height="50"
                            Click="add_purchase_btn_click"
                            Margin="30 5 5 5"
                            Grid.Column="4"
                            Style="{StaticResource dangerBtn}"/>
                </Grid>
                

            </Border>

            <ListView x:Name="purchaseListview" Grid.Row="3"  Background="{DynamicResource subBackground}"
                                  HorizontalContentAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">

                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="60" Header="{lex:Loc Key=number}"
                                        DisplayMemberBinding="{Binding RelativeSource=
                                 {RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, 
                                  Converter={StaticResource IndexConverter}}" />

                        <GridViewColumn Header="{lex:Loc Key=cate1}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label 
                                           Foreground="{DynamicResource textColor}"
                                               Width="200">
                                        <Label.Content>
                                            <AccessText TextWrapping="Wrap" Text="{Binding Path=item_name}"/>
                                        </Label.Content>
                                    </Label>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=price}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=buy_price}" 
                                           Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=qty}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=act_qty}" 
                                           Foreground="{DynamicResource textColor}"
                                               MinWidth="150"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=total}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Label Content="{Binding Path=tot}"
                                           Foreground="{DynamicResource textColor}"
                                               MinWidth="150" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{lex:Loc Key=delete}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border  Width="100" Grid.Column="5" Style="{StaticResource imag_border}"
                                             HorizontalAlignment="Center">
                                        <Image MouseDown="delete_store_item_image_md" Width="40" Height="40" Source="delete.png"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>


            </ListView>

            <Border Grid.Row="4" Margin="5"
                    CornerRadius="20"
                    HorizontalAlignment="Center"
                    Padding="10"
                    Background="{DynamicResource pageBackground}">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="5" BlurRadius="20" Color="{DynamicResource shadow1}"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="num_tb" MinWidth="150" MaxWidth="150" IsEnabled="False"/>
                    <TextBox x:Name="tot_qty_tb" MinWidth="150" MaxWidth="300" IsEnabled="False" 
                             Margin="100 0 10 0"
                             Grid.Column="1"/>
                    <TextBox x:Name="tot_price_tb" MinWidth="150" MaxWidth="300" IsEnabled="False" Grid.Column="2"/>
                </Grid>
            </Border>

            <Border Grid.Row="5" Height="100" 
                     CornerRadius="20"
                    HorizontalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Margin="5 5 5 10"   
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=date}"/>

                            <DatePicker Name="pay_date" MaxWidth="300"
                                        Text="Add Date"
                                      FontSize="18"
                                      MinWidth="200" Grid.Row="1">
                            </DatePicker>
                        </Grid>
                    </Border>
                    <Border Margin="5 5 5 10" 
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            CornerRadius="20 20 20 0"
                            Background="{DynamicResource orangeLightLinear}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="{lex:Loc Key=payment}"/>

                            <TextBox Name="pay_tb" MaxWidth="300"
                                     PreviewTextInput="qty_tb_PreviewTextInput"
                                      FontSize="18"
                                      MinWidth="200" Grid.Row="1">
                            </TextBox>
                        </Grid>
                    </Border>

                    <Button Style="{DynamicResource dangerBtn}" 
                            Margin="10 0 0 0"
                            Click="save_purchase_btn_click"
                            Width="100"
                            Height="50"
                            Content="{lex:Loc Key=save}"
                            Grid.Column="2"/>

                    <Button Style="{DynamicResource dangerBtn1}" 
                            Click="return_purchase_btn_click"
                            Margin="0 0 10 0"
                            Width="100"
                            Height="50"
                            Content="{lex:Loc Key=return}"
                            Grid.Column="4"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</UserControl>
