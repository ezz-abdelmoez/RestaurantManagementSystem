<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:properties="clr-namespace:SalesManagement.Properties"
    xmlns:src="clr-namespace:SalesManagement.files.classes"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <SolidColorBrush Color="Gray" x:Key="pageBackground"/>
    <SolidColorBrush Color="DarkGray" x:Key="subBackground"/>
    <SolidColorBrush Color="Gray"  x:Key="shadow"/>
    <Color x:Key="shadow1">#FF01579B</Color>
    <SolidColorBrush x:Key="lightGray">LightGray</SolidColorBrush>
    <SolidColorBrush x:Key="textColor">white</SolidColorBrush>


    <Style TargetType="GridViewColumnHeader">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <!--<Style TargetType="Grid">
            <Setter Property="FlowDirection" Value="RightToLeft"/>
        </Style>-->

    <src:CheckTables x:Key="checkTables"/>

    <!--StartupUri="files/test/TestWindow.xaml"-->
    <!--StartupUri="MainWindow.xaml"-->
    <FontFamily x:Key="raleway_medium_italic">assets/fonts/Raleway-MediumItalic.ttf #Raleway Medium Italic</FontFamily>
    <FontFamily x:Key="raleway_italic">assets/fonts/Raleway-Italic.ttf #Raleway Italic</FontFamily>
    <FontFamily x:Key="raleway_medium">assets/fonts/Raleway-Medium.ttf #Raleway Medium</FontFamily>
    <FontFamily x:Key="raleway_Bold">assets/fonts/Raleway-Bold.ttf #Raleway Bold</FontFamily>
    <FontFamily x:Key="raleway_bold_italic">assets/fonts/Raleway-BoldItalic.ttf #Raleway Bold Italic</FontFamily>

    <SolidColorBrush Color="#E65100" x:Key="primaryColor"/>
    <!--<SolidColorBrush Color="#B2D9D9D9" x:Key="pageBackground"/>-->

    <!-- list view item style-->
    <Style TargetType="ListViewItem">
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#FF669ECB"></Setter>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF669ECB"></Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--Listview style-->
    <Style TargetType="ListView">
        <Setter Property="ScrollViewer.CanContentScroll" Value="False"></Setter>
        <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="True"></Setter>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="Background" Value="{DynamicResource subBackground}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="10" BlurRadius="20" Color="{DynamicResource shadow1}"/>
            </Setter.Value>
        </Setter>

    </Style>

    <!--border with chadow 3d -->
    <Style TargetType="Border" x:Key="border_shadow">
        <Setter Property="Background" Value="{DynamicResource pageBackground}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="10" BlurRadius="20" Color="{DynamicResource shadow1}"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#region Radial Colors-->
    <!-- Radial colors-->
