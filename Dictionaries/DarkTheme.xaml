    <!--Border styl-->
    <Style TargetType="Border" x:Key="blueLightRadialBorder">
        <Setter Property="Background">
            <Setter.Value>
                <RadialGradientBrush>
                    <GradientStop Color="#FF01579B" Offset="0"/>
                    <GradientStop Color="#FF669ECB" Offset="1"/>
                </RadialGradientBrush>
            </Setter.Value>

        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF01579B" Offset="0"/>
                            <GradientStop Color="#FF5BC1FB" Offset="1"/>
                        </RadialGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="10" BlurRadius="20"
                                              Color="Gray"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--Button Style-->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontFamily" Value="{StaticResource raleway_bold_italic}"/>
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid>
                        <Border x:Name="background_btn"
                                            BorderThickness="1"
                                            CornerRadius="20"
                                            >
                            <Border.Background>
                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                    <GradientStop Color="#FF1B5E20" Offset="1"/>
                                    <GradientStop Color="#FF1B5E20" Offset="1"/>
                                    <GradientStop Color="#FF1B5E20"/>
                                    <GradientStop Color="Black" Offset="0.5"/>
                                </LinearGradientBrush>
                            </Border.Background>



                        </Border>
                        <ContentPresenter x:Name="content_present_btn"
                                              VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      />
                    </Grid>
                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="Background" TargetName="background_btn">
                                <Setter.Value>
                                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                        <GradientStop Color="#1B5E20" Offset="1"/>
                                        <GradientStop Color="#1B5E20" Offset="1"/>
                                        <GradientStop Color="#1B5E20"/>
                                        <GradientStop Color="#FF13C520" Offset="0.5"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="5" Color="#FF13C520"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--Button Style-->
    <Style TargetType="{x:Type Button}" x:Key="calcBtn1">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontFamily" Value="{StaticResource raleway_bold_italic}"/>
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid>
                        <Border x:Name="background_btn"
                                   BorderBrush="Black"
                                            CornerRadius="20"
                                            Background="LightGray">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="5" Color="#FF01579B"/>
                            </Border.Effect>
                        </Border>
                        <ContentPresenter x:Name="content_present_btn" VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" TargetName="background_btn" >
                                <Setter.Value>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#FF01579B" Offset="0"/>
                                        <GradientStop Color="#FF5BC1FB" Offset="1"/>
                                    </RadialGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="FontSize" Value="24"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="5" Color="#FF01579B"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--Button calc1 Style-->
    <Style TargetType="{x:Type Button}" x:Key="calcBtn">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="MinWidth" Value="35"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontFamily" Value="{StaticResource raleway_bold_italic}"/>
