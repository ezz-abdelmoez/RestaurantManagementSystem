        <GradientStop Color="Black" Offset="0.352"/>
        <GradientStop Color="#FFAA0101" Offset="1"/>
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="orangeDeepRadial">
        <GradientStop Color="#FF471C04" Offset="0"/>
        <GradientStop Color="#FFE65100" Offset="1"/>
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="blueLightRadial">
        <GradientStop Color="#FF01579B" Offset="0"/>
        <GradientStop Color="#FF669ECB" Offset="1"/>
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="blueDarkRadial">
        <GradientStop Color="#FF01579B" Offset="0"/>
        <GradientStop Color="#FF213749" Offset="1"/>
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="greenDarkLinear">
        <GradientStop Color="#FF01579B" Offset="0"/>
        <GradientStop Color="#FF213749" Offset="1"/>
    </RadialGradientBrush>
    <!--#endregion-->

