<Application x:Class="SalesManagement.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SalesManagement"
             StartupUri="/files/LoginWindow.xaml"
             xmlns:src="clr-namespace:SalesManagement.files.classes"
             xmlns:properties="clr-namespace:SalesManagement.Properties"
             >

    <!-- StartupUri="MainWindow.xaml" -->
    <Application.Resources>
        <ResourceDictionary>

            <src:IndexConverter x:Key="IndexConverter" />
            <src:MyConvertor x:Key="MyConverter" />

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Dictionaries/LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
